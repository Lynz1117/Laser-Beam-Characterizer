def parse_keyvals(line: str):
    out = {}
    parts = line.strip().split(",")
    for p in parts[1:]:
        if "=" in p:
            k, v = p.split("=", 1)
            out[k.strip()] = v.strip()
    return out


def sg_smooth_5point(y):
    y = np.asarray(y, dtype=float)
    n = len(y)
    if n < 5:
        return y.copy()

    ys = y.copy()
    ys[0]  = y[0]
    ys[1]  = y[1]
    ys[-2] = y[-2]
    ys[-1] = y[-1]

    for i in range(2, n - 2):
        ys[i] = (
            -3.0 * y[i - 2]
            + 12.0 * y[i - 1]
            + 17.0 * y[i]
            + 12.0 * y[i + 1]
            - 3.0 * y[i + 2]
        ) / 35.0

    return ys


def erf_model_idx(x_idx, x0_idx, w_idx, y_lo, y_hi):
    w_idx  = max(float(w_idx), 1e-9)
    a      = 0.5 * (y_hi - y_lo)
    x_idx  = np.asarray(x_idx, dtype=float)
    z      = (x_idx - float(x0_idx)) / w_idx
    erf_vals = np.array([math.erf(v) for v in z], dtype=float)
    return 0.5 * (y_hi + y_lo) + a * erf_vals


def estimate_erf_initial_params(y):
    y = np.asarray(y, dtype=float)
    n = len(y)
    x = np.arange(n, dtype=float)

    if n < 2:
        return 0.0, 2.0, float(y[0]) if n else 0.0, float(y[-1]) if n else 0.0

    k    = max(3, n // 10)
    y_lo = float(np.median(y[:k]))
    y_hi = float(np.median(y[-k:]))

    y_mid  = 0.5 * (y_lo + y_hi)
    x0_idx = float(x[np.argmin(np.abs(y - y_mid))])

    dy   = np.gradient(y)
    peak = float(np.max(np.abs(dy))) if len(dy) else 0.0
    amp  = abs(y_hi - y_lo)

    if peak > 1e-12:
        a = 0.5 * amp
        if a > 1e-12:
            w_idx = max((a * (2.0 / math.sqrt(math.pi))) / peak, 2.0)
        else:
            w_idx = max(n / 20.0, 2.0)
    else:
        w_idx = max(n / 20.0, 2.0)

    return x0_idx, w_idx, y_lo, y_hi


def fit_erf_curve_simple(y, max_iters=80):
    y = np.asarray(y, dtype=float)
    n = len(y)
    x = np.arange(n, dtype=float)

    x0, w, y_lo, y_hi = estimate_erf_initial_params(y)

    def sse(params):
        px0, pw, py_lo, py_hi = params
        if pw < 1e-6:
            return 1e30
        yf = erf_model_idx(x, px0, pw, py_lo, py_hi)
        e  = y - yf
        return float(np.dot(e, e))

    params = [x0, w, y_lo, y_hi]
    best   = sse(params)

    step_x0 = max(8.0, n * 0.03)
    step_w  = max(4.0, n * 0.02)
    step_y  = max(1e-6, 0.05 * max(abs(y_hi - y_lo), 1e-6))

    for _ in range(max_iters):
        improved = False

        candidates = [
            [params[0] + step_x0, params[1],               params[2],           params[3]],
            [params[0] - step_x0, params[1],               params[2],           params[3]],
            [params[0],           params[1] + step_w,      params[2],           params[3]],
            [params[0],           max(2.0, params[1] - step_w), params[2],      params[3]],
            [params[0],           params[1],               params[2] + step_y,  params[3]],
            [params[0],           params[1],               params[2] - step_y,  params[3]],
            [params[0],           params[1],               params[2],           params[3] + step_y],
            [params[0],           params[1],               params[2],           params[3] - step_y],
        ]

        for cand in candidates:
            val = sse(cand)
            if val < best:
                params   = cand
                best     = val
                improved = True

        if not improved:
            step_x0 *= 0.5
            step_w  *= 0.5
            step_y  *= 0.5
            if step_x0 < 0.05 and step_w < 0.05 and step_y < 1e-6:
                break

    return {
        "x0_idx": float(params[0]),
        "w_idx":  max(float(params[1]), 2.0),
        "y_lo":   float(params[2]),
        "y_hi":   float(params[3]),
        "sse":    float(best),
    }


def build_erf_fit_and_derivative(n, dt_s, x0_idx, w_idx, y_lo, y_hi):
    x     = np.arange(n, dtype=float)
    w_idx = max(float(w_idx), 1e-9)

    a     = 0.5 * (y_hi - y_lo)
    z     = (x - float(x0_idx)) / w_idx

    fit_y = erf_model_idx(x, x0_idx, w_idx, y_lo, y_hi)
    fit_d = a * (2.0 / math.sqrt(math.pi)) * np.exp(-(z * z)) / (w_idx * dt_s)

    return fit_y, fit_d


# =============================================================================
# Raw scan collector  (identical to t0 script)
# =============================================================================
class RawScanCollector:
    def __init__(self):
        self.reset()

    def reset(self):
        self.axis         = None
        self.scan_no      = None
        self.idx          = []
        self.enc          = []
        self.deg          = []
        self.x_mm         = []
        self.stage        = []
        self.raw          = []
        self.v            = []
        self.p_mw         = []
        self.sample_dt_ms = 1000.0 * RAW_SAMPLE_DT_S

    def start(self, axis, scan_no, sample_dt_ms=None):
        self.reset()
        self.axis    = axis
        self.scan_no = scan_no
        if sample_dt_ms is not None:
            self.sample_dt_ms = float(sample_dt_ms)

    def add(self, idx, enc, deg, x_mm, stage, raw, v, p_mw):
        self.idx.append(idx)
        self.enc.append(enc)
        self.deg.append(deg)
        self.x_mm.append(x_mm)
        self.stage.append(stage)
        self.raw.append(raw)
        self.v.append(v)
        self.p_mw.append(p_mw)

    def finalize(self):
        if self.axis is None:
            return None

        idx = np.asarray(self.idx, dtype=int)
        return {
            "axis":    int(self.axis),
            "scan_no": int(self.scan_no),
            "idx":     idx,
            "enc":     np.asarray(self.enc,   dtype=int),
            "deg":     np.asarray(self.deg,   dtype=float),
            "x_mm":    np.asarray(self.x_mm,  dtype=float),
            "stage":   np.asarray(self.stage, dtype=int),
            "raw":     np.asarray(self.raw,   dtype=int),
            "v":       np.asarray(self.v,     dtype=float),
            "p_mw":    np.asarray(self.p_mw,  dtype=float),
            "t_ms":    self.sample_dt_ms * np.arange(len(idx), dtype=float),
        }


# =============================================================================
# Per-scan processing  (aligned with t0 script, adds z_mm / step_no)
# =============================================================================
def process_one_scan(scan0, t0_info, z_mm, step_no, run_dir):
    idx_vals     = np.array(scan0["idx"],   dtype=int)
    t_ms_vals    = np.array(scan0["t_ms"],  dtype=float)
    enc_vals     = np.array(scan0["enc"],   dtype=int)
    deg_vals     = np.array(scan0["deg"],   dtype=float)
    x_mm_vals    = np.array(scan0["x_mm"], dtype=float)
    stage_vals   = np.array(scan0["stage"], dtype=int)
    raw_adc_vals = np.array(scan0["raw"],   dtype=int)
    volt_vals    = np.array(scan0["v"],     dtype=float)
    raw_p_vals   = np.array(scan0["p_mw"], dtype=float)

    if len(x_mm_vals) < 2:
        raise RuntimeError("Not enough position samples in scan.")

    dt_s = (
        1e-3 * float(np.median(np.diff(t_ms_vals)))
        if len(t_ms_vals) >= 2
        else RAW_SAMPLE_DT_S
    )

    x_local_mm = x_mm_vals - x_mm_vals[0]
    deg_local  = deg_vals  - deg_vals[0]
    enc_local  = enc_vals  - enc_vals[0]

    deg_span = float(np.max(deg_local) - np.min(deg_local))

    kernel     = np.ones(5) / 5
    avg_p_vals = np.convolve(raw_p_vals, kernel, mode="same")
    sg_p_vals  = sg_smooth_5point(avg_p_vals)

    fit     = fit_erf_curve_simple(sg_p_vals)
    fit_amp = abs(fit["y_hi"] - fit["y_lo"])

    fit_p_vals, dfit_vals = build_erf_fit_and_derivative(
        n=len(sg_p_vals),
        dt_s=dt_s,
        x0_idx=fit["x0_idx"],
        w_idx=fit["w_idx"],
        y_lo=fit["y_lo"],
        y_hi=fit["y_hi"],
    )

    t0_idx  = int(np.argmax(np.abs(dfit_vals)))
    t0_ms   = float(t_ms_vals[t0_idx])
    t0_deg  = float(deg_local[t0_idx])
    t0_x_mm = float(x_local_mm[t0_idx])
    t0_enc  = int(enc_local[t0_idx])

    x_rel_mm = x_local_mm - t0_x_mm

    profile_vals = np.abs(dfit_vals)
    profile_norm = (
        profile_vals / np.max(profile_vals)
        if np.max(profile_vals) > 0
        else profile_vals.copy()
    )

    x_span          = np.max(x_rel_mm) - np.min(x_rel_mm)
    crop_half_width = max(2.0, 0.40 * x_span)
    keep   = (x_rel_mm >= -crop_half_width) & (x_rel_mm <= crop_half_width)
    x_crop = x_rel_mm[keep]
    p_crop = profile_norm[keep]

    w_sum = np.sum(p_crop)
    if w_sum > 0:
        mu_mm           = float(np.sum(x_crop * p_crop) / w_sum)
        var_mm2         = float(np.sum(p_crop * (x_crop - mu_mm) ** 2) / w_sum)
        sigma_mm        = float(np.sqrt(max(var_mm2, 0.0)))
        width_4sigma_mm = float(4.0 * sigma_mm)
    else:
        mu_mm = sigma_mm = width_4sigma_mm = 0.0

    is_valid = (
        deg_span >= MIN_VALID_DEG_SPAN
        and fit_amp >= MIN_VALID_AMP_MW
        and 0 < sigma_mm <= MAX_VALID_SIGMA_MM
    )
    
    scan_no = int(scan0["scan_no"])
    axis    = int(scan0["axis"])

    invalid_reasons = []

    EDGE_MARGIN_DEG = 10.0
    deg_min = float(np.min(deg_local))
    deg_max = float(np.max(deg_local))

    # 1) minimum scan span
    if deg_span < MIN_VALID_DEG_SPAN:
        invalid_reasons.append(f"span={deg_span:.2f}°<{MIN_VALID_DEG_SPAN}°")

    # 2) minimum fitted amplitude
    if fit_amp < MIN_VALID_AMP_MW:
        invalid_reasons.append(f"amp={fit_amp:.4f}<{MIN_VALID_AMP_MW}mW")

    # 3) sigma bounds
    if sigma_mm <= 0 or sigma_mm > MAX_VALID_SIGMA_MM:
        invalid_reasons.append(f"sigma={sigma_mm:.4f}mm")

    # 4) t0 must not be too close to either edge of the scan window
    if (t0_deg - deg_min) <= EDGE_MARGIN_DEG or (deg_max - t0_deg) <= EDGE_MARGIN_DEG:
        invalid_reasons.append(
            f"t0 too close to edge: t0={t0_deg:.2f}°, "
            f"window=[{deg_min:.2f}°, {deg_max:.2f}°], "
            f"margin={EDGE_MARGIN_DEG:.2f}°"
        )

    # final truth: valid only if NO invalid reasons
    is_valid = (len(invalid_reasons) == 0)
    invalid_str = "; ".join(invalid_reasons)

    if not is_valid:
        INVALID_SCAN_LOG.append({
            "z_mm": z_mm,
            "step_no": step_no,
            "axis": axis,
            "scan_no": scan_no,
            "t0_deg": t0_deg,
            "t0_idx": t0_idx,
            "deg_min": deg_min,
            "deg_max": deg_max,
            "deg_span": deg_span,
            "sigma_mm": sigma_mm,
            "fit_amp_mw": fit_amp,
            "reason": invalid_str,
        })

    base_name = os.path.join(
        run_dir,
        f"z_{z_mm:07.3f}_step_{step_no:02d}_axis{axis}_scan_{scan_no:02d}"
    )

    validity_tag = "" if is_valid else " [INVALID]"

    # -------------------------------------------------------------------------
    # CSV
    # -------------------------------------------------------------------------
    header_lines = [
        f"z_mm,{z_mm}",
        f"step_no,{step_no}",
        f"scan,{scan_no}",
        f"axis,{axis}",
        f"valid,{int(is_valid)}",
        f"invalid_reason,{invalid_str}",
        f"deg_span,{deg_span}",
        f"samples,{len(t_ms_vals)}",
        f"t0_idx_python,{t0_idx}",
        f"t0_idx_stm,{t0_info.get('idx')}",
        f"t0_ms_python,{t0_ms}",
        f"t0_ms_stm,{t0_info.get('t0_ms')}",
        f"t0_deg_python_local,{t0_deg}",
        f"t0_x_mm_python_local,{t0_x_mm}",
        f"t0_enc_python_local,{t0_enc}",
        f"t0_enc_stm,{t0_info.get('t0_enc')}",
        f"x0_counts_stm,{t0_info.get('x0_counts')}",
        f"fit_x0_idx,{fit['x0_idx']}",
        f"fit_w_idx,{fit['w_idx']}",
        f"fit_ylo,{fit['y_lo']}",
        f"fit_yhi,{fit['y_hi']}",
        f"fit_amp_mw,{fit_amp}",
        f"sigma_mm,{sigma_mm}",
        f"width_4sigma_mm,{width_4sigma_mm}",
        "index,time_ms,enc_local,deg_local,x_local_mm,stage,raw_adc,voltage,"
        "raw_power_mW,sg_power_mW,erf_fit_power_mW,erf_fit_derivative,profile_norm,x_rel_mm",
    ]
    header_text = "\n".join(header_lines)

    data = np.column_stack((
        idx_vals, t_ms_vals, enc_local, deg_local, x_local_mm,
        stage_vals, raw_adc_vals, volt_vals, raw_p_vals,
        sg_p_vals, fit_p_vals, dfit_vals, profile_norm, x_rel_mm,
    ))

    csv_file = base_name + ".csv"
    np.savetxt(csv_file, data, delimiter=",", header=header_text, comments="")
    print(f"Saved CSV -> {csv_file}")
    
    # -------------------------------------------------------------------------
    # Shared watermark helper
    # -------------------------------------------------------------------------
    def add_invalid_watermark(ax):
        if is_valid:
            return
        ax.text(
            0.5, 0.5, "INVALID\n" + invalid_str,
            transform=ax.transAxes,
            fontsize=16, color="red", alpha=0.35,
            ha="center", va="center", rotation=30,
            fontweight="bold",
            bbox=dict(boxstyle="round,pad=0.3", fc="white", ec="red", alpha=0.2),
        )

    # -------------------------------------------------------------------------
    # Plot 1: Power vs Angle
    # -------------------------------------------------------------------------
    fig, ax = plt.subplots(figsize=(11, 6))
    ax.plot(deg_local, raw_p_vals, label="Raw power (mW)")
    ax.plot(deg_local, fit_p_vals, label="Erf fit power (mW)")
    ax.axvline(t0_deg, linestyle="--", label=f"T0 = {t0_deg:.4f} deg")
    ax.set_ylabel("Power (mW)")
    ax.set_xlabel("Angle (deg)")
    ax.set_title(f"Z={z_mm:.3f} mm  Step {step_no}  Axis {axis}: Power vs Angle{validity_tag}")
    ax.grid(True)
    ax.legend()
    add_invalid_watermark(ax)
    fig.savefig(base_name + "_power_vs_degree.png", dpi=300, bbox_inches="tight")
    plt.close(fig)

    # -------------------------------------------------------------------------
    # Plot 2: Derivative vs Degree
    # -------------------------------------------------------------------------
    fig, ax = plt.subplots(figsize=(11, 6))
    ax.plot(deg_local, dfit_vals, label="d/dt of erf fit")
    ax.axvline(t0_deg, linestyle="--", label=f"T0 = {t0_deg:.4f} deg")
    ax.set_xlabel("Angle (deg)")
    ax.set_ylabel("Derivative")
    ax.set_title(f"Z={z_mm:.3f} mm  Step {step_no}  Axis {axis}: Derivative vs Degree{validity_tag}")
    ax.grid(True)
    ax.legend()
    add_invalid_watermark(ax)
    fig.savefig(base_name + "_derivative_vs_degree.png", dpi=300, bbox_inches="tight")
    plt.close(fig)

    # -------------------------------------------------------------------------
    # Plot 3: T0 Overlay
    # -------------------------------------------------------------------------
    fig, ax = plt.subplots(figsize=(12, 7))
    ax.plot(deg_local, raw_p_vals, label="Raw power (mW)")
    ax.plot(deg_local, fit_p_vals, label="Erf fit power (mW)")
    ax.plot(deg_local, dfit_vals,  label="Derivative of erf fit")
    ax.axvline(t0_deg, linestyle="--", label=f"T0 = {t0_deg:.4f} deg")
    ax.set_xlabel("Angle (deg)")
    ax.set_ylabel("Signal")
    ax.set_title(f"Z={z_mm:.3f} mm  Step {step_no}  Axis {axis}: T0 Overlay{validity_tag}")
    ax.grid(True)
    ax.legend()
    add_invalid_watermark(ax)
    fig.savefig(base_name + "_overlay_vs_angle.png", dpi=300, bbox_inches="tight")
    plt.close(fig)

    # -------------------------------------------------------------------------
    # Plot 4: Beam Profile
    # -------------------------------------------------------------------------
    fig, ax = plt.subplots(figsize=(11, 6))
    ax.plot(x_rel_mm, profile_norm, label="Beam profile (normalized)")
    ax.axvline(0.0, linestyle="--", label="T0")
    ax.set_xlabel("Position relative to T0 (mm)")
    ax.set_ylabel("Normalized profile")
    ax.set_title(
        f"Z={z_mm:.3f} mm  Step {step_no}  Axis {axis}: Beam Profile "
        f"(σ={sigma_mm:.4f} mm, 4σ={width_4sigma_mm:.4f} mm){validity_tag}"
    )
    ax.grid(True)
    ax.legend()
    add_invalid_watermark(ax)
    fig.savefig(base_name + "_beam_profile.png", dpi=300, bbox_inches="tight")
    plt.close(fig)

    stm_t0_ms  = t0_info.get("t0_ms")
    stm_t0_enc = t0_info.get("t0_enc")

    print(
        f"Z={z_mm:7.3f} mm  step={step_no:02d} axis={axis}  "
        f"T0_py={t0_x_mm:.4f} mm  "
        f"T0_stm_ms={stm_t0_ms}  "
        f"T0_stm_enc={stm_t0_enc}  "
        f"sigma={sigma_mm:.6f} mm  4sigma={width_4sigma_mm:.6f} mm  "
        f"[{'OK' if is_valid else 'INVALID'}]"
    )

    return {
        "z_mm":                 z_mm,
        "step_no":              step_no,
        "scan_no":              scan_no,
        "axis":                 axis,
        "valid":                is_valid,
        "invalid_reason":       invalid_str,
        "deg_span":             deg_span,
        "samples":              len(t_ms_vals),
        "t0_idx_python":        t0_idx,
        "t0_idx_stm":           t0_info.get("idx"),
        "t0_ms_python":         t0_ms,
        "t0_ms_stm":            stm_t0_ms,
        "t0_deg_python_local":  t0_deg,
        "t0_x_mm_python_local": t0_x_mm,
        "t0_enc_python_local":  t0_enc,
        "t0_enc_stm":           stm_t0_enc,
        "x0_counts_stm":        t0_info.get("x0_counts"),
        "fit_x0_idx":           fit["x0_idx"],
        "fit_w_idx":            fit["w_idx"],
        "fit_ylo":              fit["y_lo"],
        "fit_yhi":              fit["y_hi"],
        "fit_amp_mw":           fit_amp,
        "sigma_mm":             sigma_mm,
        "width_4sigma_mm":      width_4sigma_mm,
    }


