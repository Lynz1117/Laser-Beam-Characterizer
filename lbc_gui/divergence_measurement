def save_divergence_summary(results, run_dir):
    summary_csv = os.path.join(run_dir, "divergence_summary.csv")
    with open(summary_csv, "w", newline="", encoding="utf-8") as f:
        writer = csv.writer(f)
        writer.writerow([
            "z_mm", "step_no", "scan_no", "axis", "valid", "invalid_reason",
            "deg_span", "samples",
            "t0_idx_python", "t0_idx_stm",
            "t0_ms_python", "t0_ms_stm",
            "t0_deg_python_local", "t0_x_mm_python_local", "t0_enc_python_local",
            "t0_enc_stm", "x0_counts_stm",
            "fit_x0_idx", "fit_w_idx", "fit_ylo", "fit_yhi", "fit_amp_mw",
            "sigma_mm", "width_4sigma_mm",
            "n_valid_scans", "n_total_scans",
        ])
        for r in results:
            writer.writerow([
                r["z_mm"], r["step_no"], r["scan_no"], r["axis"], int(r["valid"]),
                r["invalid_reason"], r["deg_span"], r["samples"],
                r["t0_idx_python"], r["t0_idx_stm"],
                r["t0_ms_python"], r["t0_ms_stm"],
                r["t0_deg_python_local"], r["t0_x_mm_python_local"],
                r["t0_enc_python_local"], r["t0_enc_stm"], r["x0_counts_stm"],
                r["fit_x0_idx"], r["fit_w_idx"], r["fit_ylo"], r["fit_yhi"],
                r["fit_amp_mw"], r["sigma_mm"], r["width_4sigma_mm"],
                r.get("n_valid_scans", 0), r.get("n_total_scans", 0),
            ])
    print(f"Saved summary -> {summary_csv}")
    
def save_invalid_scan_log(run_dir):
    if not INVALID_SCAN_LOG:
        print("No invalid scans logged.")
        return

    path = os.path.join(run_dir, "invalid_scans_log.csv")

    with open(path, "w", newline="", encoding="utf-8") as f:
        writer = csv.DictWriter(f, fieldnames=INVALID_SCAN_LOG[0].keys())
        writer.writeheader()
        writer.writerows(INVALID_SCAN_LOG)

    print(f"Saved invalid scan log -> {path}")


