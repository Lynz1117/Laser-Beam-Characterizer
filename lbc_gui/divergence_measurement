# Plot: hourglass / beam waist profile
# =============================================================================
def plot_beam_profile_hourglass(results, run_dir):

    def beam_hyperbola(z, w0, z0, zR):
        return w0 * np.sqrt(1.0 + ((z - z0) / zR) ** 2)

    axes = sorted(set(r["axis"] for r in results))
    for ax in axes:
        valid_ax = sorted(
            [r for r in results if r["axis"] == ax and r["valid"]],
            key=lambda r: r["z_mm"]
        )
        if len(valid_ax) < 2:
            continue

        z = np.array([r["z_mm"]    for r in valid_ax], dtype=float)
        w = np.array([r["sigma_mm"] for r in valid_ax], dtype=float)
        
        if np.ptp(z) <= 1e-9:
            print(f"Axis {ax}: Z positions not changing -> skipping hourglass fit")
            continue

        try:
            p0 = [np.min(w), z[np.argmin(w)], (np.max(z) - np.min(z)) / 2]
            popt, _ = curve_fit(beam_hyperbola, z, w, p0=p0, maxfev=10000)
            w0_fit, z0_fit, zR_fit = popt
            z_fine = np.linspace(np.min(z), np.max(z), 500)
            w_fine = beam_hyperbola(z_fine, *popt)
            fit_ok = True
        except Exception:
            fit_ok  = False
            z_fine  = np.linspace(np.min(z), np.max(z), 500)
            w_fine  = np.interp(z_fine, z, w)
            w0_fit  = z0_fit = zR_fit = None

        fig, axis_plot = plt.subplots(figsize=(13, 6))

        axis_plot.fill_between(z_fine,  w_fine, -w_fine, alpha=0.18, color="steelblue")
        axis_plot.plot(z_fine,  w_fine, color="steelblue", linewidth=2, label="Beam envelope (fit)")
        axis_plot.plot(z_fine, -w_fine, color="steelblue", linewidth=2)

        axis_plot.scatter(z,  w, color="navy", zorder=5, s=50, label="Measured σ")
        axis_plot.scatter(z, -w, color="navy", zorder=5, s=50)

        for zi, wi in zip(z, w):
            axis_plot.plot([zi, zi], [-wi * 1.05, wi * 1.05],
                           color="gray", linewidth=1.2, linestyle="-", alpha=0.5)

        axis_plot.axhline(0, color="black", linewidth=0.8, linestyle="-")

        if fit_ok and np.min(z) < z0_fit < np.max(z):
            axis_plot.axvline(z0_fit, color="red", linewidth=1.5,
                              linestyle="--",
                              label=f"Waist z={z0_fit:.1f} mm")
            offset_x = (np.max(z) - np.min(z)) * 0.04
            axis_plot.annotate(
                f"w₀ = {w0_fit:.3f} mm\nzᴿ = {abs(zR_fit):.1f} mm",
                xy=(z0_fit, w0_fit),
                xytext=(z0_fit + offset_x, w0_fit * 1.6),
                fontsize=9,
                arrowprops=dict(arrowstyle="->", color="red"),
                color="red"
            )
        elif fit_ok:
            axis_plot.text(
                0.02, 0.97,
                f"w₀={w0_fit:.3f} mm  z₀={z0_fit:.1f} mm  zᴿ={abs(zR_fit):.1f} mm",
                transform=axis_plot.transAxes,
                fontsize=8, va="top", color="red"
            )

        axis_plot.set_xlabel("Z position (mm)")
        axis_plot.set_ylabel("Beam half-width σ (mm)")
        axis_plot.set_title(f"Axis {ax}: Beam Profile — Hourglass View")
        axis_plot.legend()
        axis_plot.grid(True, alpha=0.3)

        if not np.all(np.isfinite(w_fine)):
            print(f"Axis {ax}: non-finite fit values -> skipping hourglass plot")
            plt.close(fig)
            continue

        ylim = np.max(np.abs(w_fine)) * 1.5
        if not np.isfinite(ylim) or ylim <= 0:
            print(f"Axis {ax}: invalid ylim -> skipping hourglass plot")
            plt.close(fig)
            continue

        axis_plot.set_ylim(-ylim, ylim)

        out = os.path.join(run_dir, f"axis_{ax}_hourglass.png")
        fig.savefig(out, dpi=300, bbox_inches="tight")
        plt.close(fig)
        print(f"Saved hourglass -> {out}")


