def plot_width_vs_z(results, run_dir):
    axes = sorted(set(r["axis"] for r in results))
    for ax in axes:
        valid_ax = sorted(
            [r for r in results if r["axis"] == ax and r["valid"]],
            key=lambda r: r["z_mm"]
        )
        if not valid_ax:
            continue

        z     = np.array([r["z_mm"]           for r in valid_ax], dtype=float)
        sigma = np.array([r["sigma_mm"]        for r in valid_ax], dtype=float)
        width = np.array([r["width_4sigma_mm"] for r in valid_ax], dtype=float)

        fig, axp = plt.subplots(figsize=(10, 6))
        axp.plot(z, sigma, marker="o", label="Sigma (mm)")
        axp.plot(z, width, marker="s", label="4σ width (mm)")
        axp.set_xlabel("Z position (mm)")
        axp.set_ylabel("Beam width (mm)")
        axp.set_title(f"Axis {ax}: Beam Width vs Z")
        axp.grid(True)
        axp.legend()
        fig.savefig(
            os.path.join(run_dir, f"axis_{ax}_width_vs_z.png"),
            dpi=300, bbox_inches="tight"
        )
        plt.close(fig)
        print(f"Saved width vs Z -> axis_{ax}_width_vs_z.png")


