# =============================================================================
def plot_beam_3d(results, run_dir):

    def beam_hyperbola(z, w0, z0, zR):
        return w0 * np.sqrt(1.0 + ((z - z0) / zR) ** 2)

    def fit_axis(z_data, w_data, z_fine):
        try:
            p0 = [np.min(w_data), z_data[np.argmin(w_data)],
                  (np.max(z_data) - np.min(z_data)) / 2]
            popt, _ = curve_fit(beam_hyperbola, z_data, w_data, p0=p0, maxfev=10000)
            return beam_hyperbola(z_fine, *popt), popt
        except Exception:
            return np.interp(z_fine, z_data, w_data), None

    axis0 = sorted([r for r in results if r["axis"] == 0 and r["valid"]], key=lambda r: r["z_mm"])
    axis1 = sorted([r for r in results if r["axis"] == 1 and r["valid"]], key=lambda r: r["z_mm"])

    if len(axis0) < 2 or len(axis1) < 2:
        print("Not enough valid data on both axes for 3D plot — skipping")
        return

    z0_vals = np.array([r["z_mm"]    for r in axis0])
    z1_vals = np.array([r["z_mm"]    for r in axis1])
    w0_vals = np.array([r["sigma_mm"] for r in axis0])
    w1_vals = np.array([r["sigma_mm"] for r in axis1])

    z_min  = max(np.min(z0_vals), np.min(z1_vals))
    z_max  = min(np.max(z0_vals), np.max(z1_vals))
    z_fine = np.linspace(z_min, z_max, 200)

    wx_fine, popt_x = fit_axis(z0_vals, w0_vals, z_fine)
    wy_fine, popt_y = fit_axis(z1_vals, w1_vals, z_fine)

    theta  = np.linspace(0, 2 * np.pi, 120)
    Z_surf = np.zeros((len(z_fine), len(theta)))
    X_surf = np.zeros_like(Z_surf)
    Y_surf = np.zeros_like(Z_surf)

    for i, (zi, wxi, wyi) in enumerate(zip(z_fine, wx_fine, wy_fine)):
        Z_surf[i, :] = zi
        X_surf[i, :] = wxi * np.cos(theta)
        Y_surf[i, :] = wyi * np.sin(theta)

    from mpl_toolkits.mplot3d import Axes3D  # noqa: F401

    fig   = plt.figure(figsize=(14, 8))
    ax3d  = fig.add_subplot(111, projection="3d")

    ax3d.plot_surface(Z_surf, X_surf, Y_surf,
                      alpha=0.3, color="steelblue",
                      rstride=4, cstride=4,
                      edgecolor="steelblue", linewidth=0.15)
    ax3d.plot(z_fine, np.zeros_like(z_fine), np.zeros_like(z_fine),
              color="navy", linewidth=1.5, linestyle="--", label="Beam axis")

    for r in axis0:
        th        = np.linspace(0, 2 * np.pi, 80)
        wx        = r["sigma_mm"]
        wy_interp = float(np.interp(r["z_mm"], z1_vals, w1_vals))
        ax3d.plot(np.full_like(th, r["z_mm"]),
                  wx * np.cos(th), wy_interp * np.sin(th),
                  color="red", linewidth=1.0, alpha=0.6)

    if popt_x is not None:
        w0x, z0x, _ = popt_x
        ax3d.scatter([z0x], [0], [0], color="red", s=60, zorder=10,
                     label=f"X waist z={z0x:.1f} mm  w={w0x:.3f} mm")
    if popt_y is not None:
        w0y, z0y, _ = popt_y
        ax3d.scatter([z0y], [0], [0], color="orange", s=60, zorder=10,
                     label=f"Y waist z={z0y:.1f} mm  w={w0y:.3f} mm")

    ax3d.set_xlabel("Z (mm)")
    ax3d.set_ylabel("X width (mm)")
    ax3d.set_zlabel("Y width (mm)")
    ax3d.set_title("3D Beam Envelope")
    ax3d.legend(fontsize=8)

    png_path = os.path.join(run_dir, "beam_3d_envelope.png")
    fig.savefig(png_path, dpi=300, bbox_inches="tight")
    plt.close(fig)
    print(f"Saved 3D PNG -> {png_path}")

    try:
        import plotly.graph_objects as go

        surface = go.Surface(x=Z_surf, y=X_surf, z=Y_surf,
                             opacity=0.35, colorscale="Blues",
                             showscale=False, name="Beam envelope")
        spine   = go.Scatter3d(x=z_fine, y=np.zeros_like(z_fine), z=np.zeros_like(z_fine),
                               mode="lines",
                               line=dict(color="navy", width=3, dash="dash"),
                               name="Beam axis")

        ring_traces = []
        for r in axis0:
            th        = np.linspace(0, 2 * np.pi, 80)
            wx        = r["sigma_mm"]
            wy_interp = float(np.interp(r["z_mm"], z1_vals, w1_vals))
            ring_traces.append(go.Scatter3d(
                x=np.full(len(th), r["z_mm"]),
                y=wx * np.cos(th), z=wy_interp * np.sin(th),
                mode="lines", line=dict(color="red", width=2),
                name=f"Z={r['z_mm']:.0f} mm", showlegend=False
            ))

        waist_markers = []
        if popt_x is not None:
            w0x, z0x, _ = popt_x
            waist_markers.append(go.Scatter3d(
                x=[z0x], y=[0], z=[0], mode="markers+text",
                marker=dict(color="red", size=6),
                text=[f"X waist<br>w={w0x:.3f} mm"],
                textposition="top center",
                name=f"X waist z={z0x:.1f} mm"
            ))
        if popt_y is not None:
            w0y, z0y, _ = popt_y
            waist_markers.append(go.Scatter3d(
                x=[z0y], y=[0], z=[0], mode="markers+text",
                marker=dict(color="orange", size=6),
                text=[f"Y waist<br>w={w0y:.3f} mm"],
                textposition="top center",
                name=f"Y waist z={z0y:.1f} mm"
            ))

        fig_plotly = go.Figure(data=[surface, spine] + ring_traces + waist_markers)
        fig_plotly.update_layout(
            title="3D Beam Envelope (interactive — rotate / zoom freely)",
            scene=dict(xaxis_title="Z (mm)", yaxis_title="X width (mm)",
                       zaxis_title="Y width (mm)", aspectmode="data"),
            width=1100, height=750,
            legend=dict(x=0.01, y=0.99)
        )

        html_path = os.path.join(run_dir, "beam_3d_envelope.html")
        fig_plotly.write_html(html_path)
        print(f"Saved interactive 3D -> {html_path}")

    except ImportError:
        print("plotly not installed — skipping interactive 3D HTML")
        print("Install with:  pip install plotly")


