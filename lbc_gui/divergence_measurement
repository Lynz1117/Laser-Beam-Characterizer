def calculate_divergence(results, run_dir):

    def beam_hyperbola(z, w0, z0, zR):
        return w0 * np.sqrt(1.0 + ((z - z0) / zR) ** 2)

    summary_lines = []
    axes = sorted(set(r["axis"] for r in results))

    for ax in axes:
        valid_ax = sorted(
            [r for r in results if r["axis"] == ax and r["valid"]],
            key=lambda r: r["z_mm"]
        )
        if len(valid_ax) < 3:
            print(f"Axis {ax}: not enough points for divergence fit")
            continue

        z = np.array([r["z_mm"]    for r in valid_ax], dtype=float)
        w = np.array([r["sigma_mm"] for r in valid_ax], dtype=float)
        
        if np.ptp(z) <= 1e-9:
            print(f"Axis {ax}: Z positions not changing -> skipping divergence fit")
            continue

        try:
            p0 = [np.min(w), z[np.argmin(w)], (np.max(z) - np.min(z)) / 2]
            popt, pcov = curve_fit(beam_hyperbola, z, w, p0=p0, maxfev=10000)
            w0_mm, z0_mm, zR_mm = popt
            perr = np.sqrt(np.diag(pcov))

            theta_div_rad   = abs(w0_mm / zR_mm)
            theta_div_mrad  = theta_div_rad * 1000.0
            theta_full_mrad = 2.0 * theta_div_mrad

            line = (
                f"Axis {ax}:\n"
                f"  w0     = {w0_mm:.4f} mm  ({w0_mm*1000:.2f} µm)\n"
                f"  z0     = {z0_mm:.2f} mm\n"
                f"  zR     = {abs(zR_mm):.2f} mm\n"
                f"  θ_div  = {theta_div_mrad:.4f} mrad  (half-angle)\n"
                f"  2θ_div = {theta_full_mrad:.4f} mrad  (full angle)\n"
                f"  Fit σ: w0±{perr[0]:.4f}  z0±{perr[1]:.2f}  zR±{perr[2]:.2f}\n"
            )
            summary_lines.append(line)
            print(line)

            fig, axp = plt.subplots(figsize=(12, 6))

            z_ext = np.linspace(z0_mm - abs(zR_mm) * 3,
                                z0_mm + abs(zR_mm) * 3, 500)
            w_ext = beam_hyperbola(z_ext, *popt)

            axp.plot(z_ext, w_ext, color="steelblue", linewidth=2,
                     label="Gaussian beam fit")
            axp.scatter(z, w, color="navy", zorder=5, s=60,
                        label="Measured σ")

            z_fwd = np.array([z0_mm, z0_mm + abs(zR_mm) * 3])
            z_bwd = np.array([z0_mm - abs(zR_mm) * 3, z0_mm])
            axp.plot(z_fwd,  theta_div_rad * (z_fwd - z0_mm),
                     "r--", linewidth=1.2,
                     label=f"θ_div = {theta_div_mrad:.3f} mrad")
            axp.plot(z_fwd, -theta_div_rad * (z_fwd - z0_mm), "r--", linewidth=1.2)
            axp.plot(z_bwd,  theta_div_rad * (z0_mm - z_bwd), "r--", linewidth=1.2)
            axp.plot(z_bwd, -theta_div_rad * (z0_mm - z_bwd), "r--", linewidth=1.2)

            axp.axvline(z0_mm + abs(zR_mm), color="green",
                        linestyle=":", linewidth=1.2, alpha=0.7,
                        label=f"±zR = {abs(zR_mm):.1f} mm")
            axp.axvline(z0_mm - abs(zR_mm), color="green",
                        linestyle=":", linewidth=1.2, alpha=0.7)
            axp.axvline(z0_mm, color="gray",
                        linestyle="--", linewidth=1.0, alpha=0.5,
                        label=f"Waist z={z0_mm:.1f} mm")

            axp.annotate(
                f"w₀ = {w0_mm*1000:.2f} µm\nθ = {theta_div_mrad:.3f} mrad",
                xy=(z0_mm, w0_mm),
                xytext=(z0_mm + abs(zR_mm) * 0.5, w0_mm * 2.5),
                fontsize=10,
                arrowprops=dict(arrowstyle="->", color="black"),
            )

            axp.set_xlabel("Z position (mm)")
            axp.set_ylabel("Beam half-width σ (mm)")
            axp.set_title(
                f"Axis {ax}: Divergence — "
                f"θ_div = {theta_div_mrad:.3f} mrad  "
                f"w₀ = {w0_mm*1000:.2f} µm"
            )
            axp.grid(True, alpha=0.3)
            axp.legend()

            out = os.path.join(run_dir, f"axis_{ax}_divergence.png")
            fig.savefig(out, dpi=300, bbox_inches="tight")
            plt.close(fig)
            print(f"Saved divergence plot -> {out}")

        except Exception as e:
            print(f"Axis {ax}: divergence fit failed — {e}")
            summary_lines.append(f"Axis {ax}: fit failed — {e}\n")

    txt_path = os.path.join(run_dir, "divergence_results.txt")
    with open(txt_path, "w", encoding="utf-8") as f:
        f.write("\n".join(summary_lines))
    print(f"Saved divergence results -> {txt_path}")


# =============================================================================
# Serial receive loop  (aligned with t0 script)
# =============================================================================
def run_divergence_batch(ser, run_dir):
    print(f"Sending command: {CMD.decode().strip()}")
    ser.reset_input_buffer()
    ser.reset_output_buffer()
    ser.write(CMD)

    collector = RawScanCollector()

    # Keys are (axis, scan_no) — same pattern as t0 script.
    # z_mm / step_no context is tracked separately and written into the result
    # record when a scan is processed.
    raw_scans  = {}   # (axis, scan_no) -> scan dict
    t0_results = {}   # (axis, scan_no) -> t0 info dict
    processed  = set()
    results    = []

    current_z_mm    = 0.0
    current_step_no = 0
    current_axis    = 0
    
    stm_invalid_scans = set()

    # Per-(axis,scan_no) z/step context recorded at RAW_SCAN_BEGIN time so it
    # is available when the scan is processed later.
    scan_context = {}   # (axis, scan_no) -> {"z_mm": ..., "step_no": ...}

    empty_count = 0
    batch_done  = False

    while not batch_done:
        line = ser.readline().decode(errors="ignore").strip()

        if not line:
            empty_count += 1
            if empty_count > EMPTY_LIMIT:
                raise RuntimeError("Timed out waiting for divergence data.")
            continue

        empty_count = 0
        print(line)

        if line.startswith("DIV_POS_BEGIN"):
            kv = parse_keyvals(line)
            current_z_mm    = float(kv.get("z_mm", str(current_z_mm)))
            current_step_no = int(kv.get("step", str(current_step_no)))

        elif line.startswith("DIV_AXIS_BEGIN"):
            kv = parse_keyvals(line)
            current_z_mm    = float(kv.get("z_mm",  str(current_z_mm)))
            current_step_no = int(kv.get("step",    str(current_step_no)))
            current_axis    = int(kv.get("axis",    str(current_axis)))
            
        elif line.startswith("Z_MOVE_DONE"):
            kv = parse_keyvals(line)
            current_z_mm = float(kv.get("z_mm", str(current_z_mm)))
            current_step_no = int(kv.get("step", str(current_step_no)))

        elif line.startswith("RAW_SCAN_BEGIN"):
            kv = parse_keyvals(line)

            scan_axis = int(kv.get("axis", str(current_axis)))
            scan_no   = int(kv.get("scan", "0"))

            stride      = float(kv.get("stride", "1"))
            emit_stride = float(kv.get("emit_stride", "1"))
            sample_dt_ms = 1000.0 * RAW_SAMPLE_DT_S * stride * emit_stride

            scan_key = (current_step_no, scan_axis, scan_no)

            collector.start(
                axis=scan_axis,
                scan_no=scan_no,
                sample_dt_ms=sample_dt_ms
            )

            scan_context[scan_key] = {
                "z_mm": current_z_mm,
                "step_no": current_step_no,
            }

        elif line.startswith("RAW_SCAN,"):
            parts = line.split(",")
            if len(parts) != 11:
                continue
            try:
                collector.add(
                    idx=int(parts[3]),
                    enc=int(parts[4]),
                    deg=float(parts[5]),
                    x_mm=float(parts[6]),
                    stage=int(parts[7]),
                    raw=int(parts[8]),
                    v=float(parts[9]),
                    p_mw=float(parts[10]),
                )
            except ValueError:
                continue
            
        elif line.startswith("T0_SCAN_INVALID"):
            kv = parse_keyvals(line)
            axis = int(kv.get("axis", "0"))
            scan_no = int(kv.get("scan", "0"))
            key = (current_step_no, axis, scan_no)

            stm_invalid_scans.add(key)

        elif line.startswith("RAW_SCAN_DONE"):
            scan = collector.finalize()
            if scan is not None:
                key = (current_step_no, scan["axis"], scan["scan_no"])
                raw_scans[key] = scan

                if key in t0_results and key not in processed and key not in stm_invalid_scans:
                    ctx = scan_context.get(key, {"z_mm": current_z_mm, "step_no": current_step_no})
                    result = process_one_scan(
                        raw_scans[key], t0_results[key],
                        z_mm=ctx["z_mm"],
                        step_no=ctx["step_no"],
                        run_dir=run_dir,
                    )
                    results.append(result)
                    processed.add(key)

        elif line.startswith("T0_RESULT"):
            kv      = parse_keyvals(line)
            axis    = int(kv.get("axis", str(current_axis)))
            scan_no = int(kv.get("scan", "0"))
            key = (current_step_no, axis, scan_no)

            t0_results[key] = {
                "axis":      axis,
                "scan":      scan_no,
                "idx":       int(float(kv.get("idx",       "0"))),
                "t0_ms":     float(kv.get("t0_ms",     "0")) if "t0_ms"     in kv else None,
                "t0_enc":    int(float(kv.get("t0_enc", "0"))) if "t0_enc"  in kv else None,
                "x0_counts": int(float(kv.get("x0_counts","0"))) if "x0_counts" in kv else None,
            }

            if key in raw_scans and key not in processed:
                ctx = scan_context.get(key, {"z_mm": current_z_mm,
                                             "step_no": current_step_no})
                result = process_one_scan(
                    raw_scans[key], t0_results[key],
                    z_mm=ctx["z_mm"],
                    step_no=ctx["step_no"],
                    run_dir=run_dir,
                )
                results.append(result)
                processed.add(key)

        elif line.startswith("DIV_AXIS_FAIL"):
            print(f"WARNING: axis failure reported: {line}")

        elif line.startswith("T0_FAIL"):
            print(f"WARNING: T0 failure reported: {line}")

        elif line.startswith("DIVERGENCE_DONE"):
            batch_done = True

    return sorted(results, key=lambda r: (r["z_mm"], r["axis"], r["scan_no"]))


def average_valid_scans_per_z_axis(results):
    grouped = {}

    for r in results:
        key = (float(r["z_mm"]), int(r["axis"]))
        grouped.setdefault(key, []).append(r)

    averaged = []

    for (z_mm, axis), scans in sorted(grouped.items(), key=lambda kv: (kv[0][0], kv[0][1])):
        valid_scans = [r for r in scans if r["valid"]]

        if not valid_scans:
            averaged.append({
                "z_mm": z_mm,
                "step_no": min(r["step_no"] for r in scans),
                "scan_no": -1,
                "axis": axis,
                "valid": False,
                "invalid_reason": "no valid scans",
                "deg_span": 0.0,
                "samples": 0,
                "t0_idx_python": 0,
                "t0_idx_stm": 0,
                "t0_ms_python": 0.0,
                "t0_ms_stm": 0.0,
                "t0_deg_python_local": 0.0,
                "t0_x_mm_python_local": 0.0,
                "t0_enc_python_local": 0,
                "t0_enc_stm": 0,
                "x0_counts_stm": 0,
                "fit_x0_idx": 0.0,
                "fit_w_idx": 0.0,
                "fit_ylo": 0.0,
                "fit_yhi": 0.0,
                "fit_amp_mw": 0.0,
                "sigma_mm": 0.0,
                "width_4sigma_mm": 0.0,
                "n_valid_scans": 0,
                "n_total_scans": len(scans),
            })
            continue

        averaged.append({
            "z_mm": z_mm,
            "step_no": min(r["step_no"] for r in valid_scans),
            "scan_no": -1,
            "axis": axis,
            "valid": True,
            "invalid_reason": "",
            "deg_span": float(np.mean([r["deg_span"] for r in valid_scans])),
            "samples": int(round(np.mean([r["samples"] for r in valid_scans]))),
            "t0_idx_python": int(round(np.mean([r["t0_idx_python"] for r in valid_scans]))),
            "t0_idx_stm": int(round(np.mean([
                r["t0_idx_stm"] for r in valid_scans if r["t0_idx_stm"] is not None
            ]))) if any(r["t0_idx_stm"] is not None for r in valid_scans) else 0,
            "t0_ms_python": float(np.mean([r["t0_ms_python"] for r in valid_scans])),
            "t0_ms_stm": float(np.mean([
                r["t0_ms_stm"] for r in valid_scans if r["t0_ms_stm"] is not None
            ])) if any(r["t0_ms_stm"] is not None for r in valid_scans) else 0.0,
            "t0_deg_python_local": float(np.mean([r["t0_deg_python_local"] for r in valid_scans])),
            "t0_x_mm_python_local": float(np.mean([r["t0_x_mm_python_local"] for r in valid_scans])),
            "t0_enc_python_local": int(round(np.mean([r["t0_enc_python_local"] for r in valid_scans]))),
            "t0_enc_stm": int(round(np.mean([
                r["t0_enc_stm"] for r in valid_scans if r["t0_enc_stm"] is not None
            ]))) if any(r["t0_enc_stm"] is not None for r in valid_scans) else 0,
            "x0_counts_stm": int(round(np.mean([
                r["x0_counts_stm"] for r in valid_scans if r["x0_counts_stm"] is not None
            ]))) if any(r["x0_counts_stm"] is not None for r in valid_scans) else 0,
            "fit_x0_idx": float(np.mean([r["fit_x0_idx"] for r in valid_scans])),
            "fit_w_idx": float(np.mean([r["fit_w_idx"] for r in valid_scans])),
            "fit_ylo": float(np.mean([r["fit_ylo"] for r in valid_scans])),
            "fit_yhi": float(np.mean([r["fit_yhi"] for r in valid_scans])),
            "fit_amp_mw": float(np.mean([r["fit_amp_mw"] for r in valid_scans])),
            "sigma_mm": float(np.mean([r["sigma_mm"] for r in valid_scans])),
            "width_4sigma_mm": float(np.mean([r["width_4sigma_mm"] for r in valid_scans])),
            "n_valid_scans": len(valid_scans),
            "n_total_scans": len(scans),
        })

    return averaged

# =============================================================================
# Main
# =============================================================================
def main():
    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    run_dir   = os.path.join(SAVE_DIR, f"divergence_{timestamp}")
    os.makedirs(run_dir, exist_ok=True)

    print(f"Opening {PORT} @ {BAUD}")
    ser = serial.Serial(PORT, BAUD, timeout=SERIAL_TIMEOUT_S)

    try:
        raw_results = run_divergence_batch(ser, run_dir)
    finally:
        ser.close()

    results = average_valid_scans_per_z_axis(raw_results)

    # -------------------------------------------------------------------------
    # Console summary
    # -------------------------------------------------------------------------
    print("\n===== Divergence Summary =====")
    z_positions = sorted(set(r["z_mm"] for r in results))

    for z in z_positions:
        print(f"\nZ = {z:.3f} mm")
        z_results = sorted(
            [r for r in results if r["z_mm"] == z],
            key=lambda r: r["axis"]
        )
        for r in z_results:
            tag = "OK" if r["valid"] else f"INVALID ({r['invalid_reason']})"
            n_valid = r.get("n_valid_scans", 0)
            n_total = r.get("n_total_scans", 0)
            print(
                f"  Axis {r['axis']}: "
                f"T0_x={r['t0_x_mm_python_local']:.4f} mm  "
                f"sigma_avg={r['sigma_mm']:.6f} mm  "
                f"4sigma_avg={r['width_4sigma_mm']:.6f} mm  "
                f"valid_scans={n_valid}/{n_total}  "
                f"[{tag}]"
            )

    save_divergence_summary(results, run_dir)
    save_invalid_scan_log(run_dir)

    print("\nGenerating plots...")
    plot_width_vs_z(results, run_dir)
    plot_beam_profile_hourglass(results, run_dir)
    plot_beam_3d(results, run_dir)
    calculate_divergence(results, run_dir)

    print(f"\nAll outputs saved in: {run_dir}")


if __name__ == "__main__":
    main()