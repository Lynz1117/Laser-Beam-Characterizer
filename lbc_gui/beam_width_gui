def update_axes(ax):
    ax.relim()
    ax.autoscale_view()

def set_last_result_dict(res, mode_label):
    global last_result
    ts = datetime.now().strftime("%Y-%m-%d_%H-%M-%S")
    last_result = {
        "timestamp": ts,
        "mode": mode_label,
        "deg_g": res["deg_g"],
        "v_s": res["v_s"],
        "x_u": res["x_u"],
        "P_u": res["P_u"],
        "x_mid": res["x_mid"],
        "prof": res["prof"],
        "bw": res["bw"],
        "settings": {
            "R_MM": R_MM, "MA_W": MA_W, "DROP_N": DROP_N,
            "DEG_STEP": DEG_STEP, "DX_MM": DX_MM
        }
    }

def update_display(res, label=""):
    line_v.set_data(res["deg_g"], res["v_s"])
    update_axes(ax1)

    line_p.set_data(res["x_u"], res["P_u"])
    update_axes(ax2)

    line_d.set_data(res["x_mid"], res["prof"])
    update_axes(ax3)

    bw = res["bw"]
    if bw is not None:
        Area, center, sigma, D4s = bw
        vline_l.set_xdata([center - 2*sigma, center - 2*sigma]); vline_l.set_visible(True)
        vline_r.set_xdata([center + 2*sigma, center + 2*sigma]); vline_r.set_visible(True)

        status.set_text(
            f"Status: Done {label} | Area={Area:.4e} | D4σ={D4s:.4f} mm | center={center:.4f} mm | σ={sigma:.4f} mm"
        )
    else:
        vline_l.set_visible(False)
        vline_r.set_visible(False)
        status.set_text(f"Status: Done {label} | Beam width not computed")

    fig.canvas.draw_idle()

# =======================
# Background worker control
# =======================
def start_worker(kind):
    global running, stop_requested, worker_thread
    if running:
        return
    running = True
    stop_requested = False

    def worker():
        try:
            if kind == "single":
                result_q.put({"type": "status", "text": "Status: Scanning (1x)..."})
                deg_raw, v_raw = acquire_one_scan()
                if deg_raw is None:
                    result_q.put({"type": "error", "text": "Scan canceled / not enough data"})
                    return
                res = process_one_scan(deg_raw, v_raw)
                set_last_result_dict(res, "single")
                result_q.put({"type": "done", "res": res, "label": "(1 scan)"})

            elif kind == "avg":
                result_q.put({"type": "status", "text": f"Status: Scanning (avg {NUM_AVG})..."})
                res = process_avg_scans(NUM_AVG)
                if res is None:
                    result_q.put({"type": "error", "text": "Avg canceled / scan failed"})
                    return
                set_last_result_dict(res, f"avg{NUM_AVG}")
                result_q.put({"type": "done", "res": res, "label": f"(avg {NUM_AVG})"})

        except Exception as e:
            result_q.put({"type": "error", "text": f"Exception: {e}"})
        finally:
            # tell UI we stopped
            result_q.put({"type": "stopped"})

    worker_thread = threading.Thread(target=worker, daemon=True)
    worker_thread.start()

def pump_results():
    global running
    try:
        while True:
            msg = result_q.get_nowait()
            t = msg.get("type")

            if t == "status":
                status.set_text(msg["text"])
                fig.canvas.draw_idle()

            elif t == "done":
                # ensure last_result is set even if worker didn't
                if last_result is None:
                    set_last_result_dict(msg["res"], "unknown")
                update_display(msg["res"], label=msg.get("label", ""))

            elif t == "error":
                status.set_text("Status: " + msg["text"])
                fig.canvas.draw_idle()

            elif t == "stopped":
                running = False
                # restore button labels
                btn_start.label.set_text("Start Scan")
                btn_avg.label.set_text(f"Avg {NUM_AVG}")
                fig.canvas.draw_idle()

    except queue.Empty:
        pass

timer = fig.canvas.new_timer(interval=50)
timer.add_callback(pump_results)
timer.start()

