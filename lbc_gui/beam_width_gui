def on_start(event=None):
    btn_start.label.set_text("Running...")
    fig.canvas.draw_idle()
    start_worker("single")

def on_avg(event=None):
    btn_avg.label.set_text("Running...")
    fig.canvas.draw_idle()
    start_worker("avg")

def on_stop(event=None):
    global stop_requested
    stop_requested = True

    # tell STM32 to stop streaming immediately (if supported)
    try:
        ser.write(ABORT_CMD)
        ser.flush()
    except Exception:
        pass

    status.set_text("Status: Stop requested...")
    fig.canvas.draw_idle()

def on_clear(event=None):
    global last_result
    last_result = None
    line_v.set_data([], [])
    line_p.set_data([], [])
    line_d.set_data([], [])
    vline_l.set_visible(False)
    vline_r.set_visible(False)
    status.set_text("Status: Cleared / Ready")
    update_axes(ax1); update_axes(ax2); update_axes(ax3)
    fig.canvas.draw_idle()

def on_save(event=None):
    global last_result

    if last_result is None:
        status.set_text("Status: Nothing to save yet (run a scan first).")
        fig.canvas.draw_idle()
        return

    ts = last_result["timestamp"]
    mode = last_result["mode"]
    base = os.path.join(SAVE_DIR, f"{ts}_{mode}")

    try:
        np.savetxt(
            base + "_voltage_vs_angle.csv",
            np.column_stack([last_result["deg_g"], last_result["v_s"]]),
            delimiter=",", header="deg,volts", comments=""
        )

        np.savetxt(
            base + "_knife_edge_Px.csv",
            np.column_stack([last_result["x_u"], last_result["P_u"]]),
            delimiter=",", header="x_mm,P_norm", comments=""
        )

        np.savetxt(
            base + "_profile_dPdx.csv",
            np.column_stack([last_result["x_mid"], last_result["prof"]]),
            delimiter=",", header="x_mm,dP_dx", comments=""
        )

        bw = last_result["bw"]
        with open(base + "_summary.txt", "w") as f:
            f.write(f"timestamp: {ts}\n")
            f.write(f"mode: {mode}\n")
            for k, v in last_result["settings"].items():
                f.write(f"{k}: {v}\n")
            if bw is None:
                f.write("beam_width: not computed\n")
            else:
                Area, center, sigma, D4s = bw
                f.write("\nBeam width (MATLAB trapz moment method):\n")
                f.write(f"Area:   {Area:.6e}\n")
                f.write(f"Center: {center:.6f} mm\n")
                f.write(f"Sigma:  {sigma:.6f} mm\n")
                f.write(f"D4sigma:    {D4s:.6f} mm\n")

        fig.savefig(base + "_plots.png", dpi=200)

        status.set_text(f"Status: Saved to {SAVE_DIR}")
        fig.canvas.draw_idle()
        print("[PY] Saved files base:", base)

    except Exception as e:
        status.set_text(f"Status: SAVE FAILED: {type(e).__name__}: {e}")
        fig.canvas.draw_idle()
        print("[PY] SAVE FAILED:", repr(e))

