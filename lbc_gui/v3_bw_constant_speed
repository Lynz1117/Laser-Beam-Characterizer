def save_last_result():
    if sess.last_result is None:
        print("No averaged result to save.")
        return

    out_dir = os.getcwd()
    ts = datetime.now().strftime("%Y%m%d_%H%M%S")

    # Save averaged processed result
    avg_path = os.path.join(out_dir, f"beam_profile_avg_{ts}.csv")

    r = sess.last_result
    n1 = len(r["x_mm"])
    n2 = len(r["x_prof"])

    with open(avg_path, "w", encoding="utf-8") as f:
        f.write(f"# 4sigma_width_mm,{r['width_4sigma']}\n")
        f.write(f"# sigma_mm,{r['sigma']}\n")
        f.write(f"# mu_mm,{r['mu']}\n")
        f.write("x_mm,signal_smoothed,power_mw_smoothed,normalized_power,profile_x_mm,beam_profile\n")

        for i in range(max(n1, n2)):
            c1 = ""
            c2 = ""
            c3 = ""
            c4 = ""
            c5 = ""
            c6 = ""

            if i < n1:
                c1 = f"{r['x_mm'][i]:.6f}"
                c2 = f"{r['v_s'][i]:.6f}"
                c3 = f"{r['p_mw'][i]:.6f}"
                c4 = f"{r['P'][i]:.6f}"

            if i < n2:
                c5 = f"{r['x_prof'][i]:.6f}"
                c6 = f"{r['profile'][i]:.6f}"

            f.write(f"{c1},{c2},{c3},{c4},{c5},{c6}\n")

    print("Saved averaged result:", avg_path)

    # Save all raw scans too
    save_all_scans_csv()
    
def save_all_scans_csv():
    if not sess.raw_scans:
        print("No scan set to save.")
        return

    out_dir = os.getcwd()
    ts = datetime.now().strftime("%Y%m%d_%H%M%S")
    path = os.path.join(out_dir, f"beam_profiles_10scans_{ts}.csv")

    with open(path, "w", encoding="utf-8") as f:
        f.write("scan_no,point_idx,t_ms,deg,stage,raw,v,p_mw\n")

        for scan in sess.raw_scans:
            n = len(scan["t_ms"])
            for i in range(n):
                f.write(
                    f"{scan['scan_no']},"
                    f"{i},"
                    f"{scan['t_ms'][i]:.6f},"
                    f"{scan['deg'][i]:.6f},"
                    f"{scan['stage'][i]},"
                    f"{scan['raw'][i]},"
                    f"{scan['v'][i]:.6f},"
                    f"{scan['p_mw'][i]:.6f}\n"
                )

    print("Saved all beam profiles:", path)


