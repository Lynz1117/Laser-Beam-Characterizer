def finalize_current_scan():
    if not sess.cur_t_ms:
        return

    # Save raw scan first
    raw_scan = {
        "scan_no": sess.cur_scan_no,
        "t_ms": np.array(sess.cur_t_ms, dtype=float),
        "deg": np.array(sess.cur_deg, dtype=float),
        "v": np.array(sess.cur_v, dtype=float),
        "raw": np.array(sess.cur_raw, dtype=int),
        "p_mw": np.array(sess.cur_p_mw, dtype=float),
        "stage": np.array(sess.cur_stage, dtype=int),
    }
    sess.raw_scans.append(raw_scan)

    # Process current scan
    if sess.cur_p_mw:
        result = process_scan(sess.cur_t_ms, sess.cur_deg, sess.cur_p_mw, sess.cur_v)
    else:
        if not sess.cur_v:
            reset_current_scan_buffers()
            return
        result = process_scan(sess.cur_t_ms, sess.cur_deg, sess.cur_v, sess.cur_v)

    if result is not None:
        # If scan 0 is the initial long scan, do not include it in averaging
        if sess.cur_scan_no != 0:
            sess.processed_scans.append(result)
            sess.done_scans += 1

        # One-scan mode
        if sess.target_scans <= 1:
            sess.last_result = result

        # Multi-scan mode: always plot the running average
        else:
            avg_result = average_processed_scans(sess.processed_scans)
            if avg_result is not None:
                sess.last_result = avg_result

        update_plots(sess.last_result)

    reset_current_scan_buffers()

    if sess.done_scans >= sess.target_scans:
        sess.active = False

def pump_serial():
    did_work = False

    while True:
        try:
            line = rx_q.get_nowait()
        except queue.Empty:
            break

        did_work = True
        print(line)
        
        if line.startswith("BM,"):
            print("BM DATA RECEIVED")
            
        if line == "BM_DONE":
            print("BM_DONE RECEIVED")

            if sess.cur_t_ms:
                finalize_current_scan()

            continue

        if line.startswith("PROFILE_BEGIN") or line.startswith("PROFILE_T0") or line.startswith("PROFILE_SCAN_") or line == "PROFILE_DONE" or line == "PROFILE_ABORT":
            if line == "PROFILE_DONE":
                if sess.cur_t_ms:
                    finalize_current_scan()
                sess.active = False

            if line == "PROFILE_ABORT":
                sess.active = False

            continue

        parsed = parse_bm(line)
        if parsed is None:
            continue

        # Only BM lines matter now
        if parsed["kind"] == "BM":

            sess.last_bm_wall = time.time()

            scan_no = parsed["scan"]
            t_ms = parsed["t_ms"]
            deg = parsed["deg"]
            v = parsed["v"]
            raw = parsed["raw"]
            p_mw = parsed["p_mw"]
            stage = parsed["stage"]

            if sess.cur_scan_no is None:
                sess.cur_scan_no = scan_no
            elif scan_no != sess.cur_scan_no and sess.cur_t_ms:
                finalize_current_scan()
                sess.cur_scan_no = scan_no

            sess.cur_t_ms.append(t_ms)
            sess.cur_deg.append(deg)
            sess.cur_v.append(v)
            sess.cur_raw.append(raw)
            sess.cur_p_mw.append(p_mw)
            sess.cur_stage.append(stage)

    return did_work


timer = fig1.canvas.new_timer(interval=50)

def on_timer():
    pump_serial()

    if sess.active:
        if sess.last_bm_wall is not None:
            if (time.time() - sess.last_bm_wall) > STALL_TIMEOUT_S:
                print("Stall timeout: BM stream stopped.")
                sess.active = False
        elif sess.scan_start_wall is not None:
            if (time.time() - sess.scan_start_wall) > 5.0:
                print("Timeout: PROFILE started but no BM data arrived.")
                sess.active = False

timer.add_callback(on_timer)
timer.start()


