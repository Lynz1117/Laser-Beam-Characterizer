# Fake serial data generator
# ============================================================
def make_fake_scan_lines():
    """
    Create fake STM32 lines:
      BM,scan_no,t_ms,deg,stage,raw,v,p_mw
      ...
      BM_DONE
    """
    lines = []

    dt_ms = 8
    total_ms = 180
    n = total_ms // dt_ms + 1

    v_lo = 0.08
    v_hi = 0.80

    for i in range(n):
        t_ms = i * dt_ms
        deg = 25.0 * (t_ms / total_ms)

        # Falling S-curve
        t0 = 95.0
        k = 10.0
        p_norm = 1.0 / (1.0 + math.exp((t_ms - t0) / k))

        noise = np.random.normal(0.0, 0.004)
        ripple = 0.003 * math.sin(2.0 * math.pi * t_ms / 40.0)

        v = v_lo + (v_hi - v_lo) * p_norm + noise + ripple
        v = max(0.0, v)

        stage = 1
        raw = int(np.clip((v / 3.3) * 4095, 0, 4095))
        p_mw = max(0.0, 3.0 * p_norm + 0.02 * np.random.randn())

        lines.append(f"BM,1,{t_ms:.3f},{deg:.6f},{stage},{raw},{v:.6f},{p_mw:.6f}")

    lines.append("BM_DONE")
    return lines


def send_fake_scan():
    lines = make_fake_scan_lines()

    def worker():
        try:
            rx_q.put_nowait("PROFILE_BEGIN,omega=1.1000,ts_ms=180,t90_s=1.42,twait_s=1.24")
        except queue.Full:
            pass

        for line in lines:
            if stop_reader:
                return

            if sess.abort or not sess.active:
                return

            try:
                rx_q.put_nowait(line)
            except queue.Full:
                pass

            time.sleep(0.02)

        try:
            rx_q.put_nowait("PROFILE_SCAN_DONE,n=1")
            rx_q.put_nowait("PROFILE_DONE")
        except queue.Full:
            pass

    threading.Thread(target=worker, daemon=True).start()


# ============================================================
# Serial reader thread
# ============================================================
rx_q = queue.Queue(maxsize=50000)
stop_reader = False

if not USE_FAKE_SERIAL:
    ser = serial.Serial(PORT, BAUD, timeout=0.1)
else:
    ser = None


def reader_thread():
    global stop_reader

    if USE_FAKE_SERIAL:
        while not stop_reader:
            time.sleep(0.05)
        return

    buf = b""
    while not stop_reader:
        try:
            data = ser.read(ser.in_waiting or 1)
            if not data:
                continue

            buf += data

            while b"\n" in buf:
                line, buf = buf.split(b"\n", 1)
                s = line.decode(errors="ignore").strip()
                try:
                    rx_q.put_nowait(s)
                except queue.Full:
                    try:
                        rx_q.get_nowait()
                    except queue.Empty:
                        pass
        except Exception:
            pass


threading.Thread(target=reader_thread, daemon=True).start()


