# Session state
# ============================================================
class Session:
    def __init__(self):
        self.active = False
        self.abort = False
        self.target_scans = 1
        self.done_scans = 0

        self.cur_scan_no = None
        self.cur_t_ms = []
        self.cur_deg = []
        self.cur_v = []
        self.cur_raw = []
        self.cur_p_mw = []
        self.cur_stage = []

        self.processed_scans = []
        self.raw_scans = []
        self.last_result = None

        self.scan_start_wall = None
        self.last_bm_wall = None


sess = Session()


def flush_rx():
    while True:
        try:
            rx_q.get_nowait()
        except queue.Empty:
            break


def reset_current_scan_buffers():
    sess.cur_scan_no = None
    sess.cur_t_ms.clear()
    sess.cur_deg.clear()
    sess.cur_v.clear()
    sess.cur_raw.clear()
    sess.cur_p_mw.clear()
    sess.cur_stage.clear()


def start_session(target_scans=1):
    sess.active = True
    sess.abort = False
    sess.target_scans = target_scans
    sess.done_scans = 0
    sess.processed_scans = []
    sess.raw_scans = []
    sess.last_result = None
    sess.scan_start_wall = time.time()
    sess.last_bm_wall = None
    reset_current_scan_buffers()
    flush_rx()

    if USE_FAKE_SERIAL:
        send_fake_scan()
    else:
        ser.reset_input_buffer()
        ser.reset_output_buffer()
        ser.write(START_CMD)


def abort_session():
    sess.abort = True
    sess.active = False
    if not USE_FAKE_SERIAL:
        try:
            ser.write(ABORT_CMD)
        except Exception:
            pass


