# ============================================================
# Main acquisition
# ============================================================
timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
run_dir = os.path.join(SAVE_ROOT, f"profile_run_{timestamp}")
ensure_dir(run_dir)

ser = serial.Serial(PORT, BAUD, timeout=SERIAL_TIMEOUT_S)
ser.reset_input_buffer()
ser.reset_output_buffer()

print(f"Opening {PORT} @ {BAUD}")
print(f"Sending command: {START_CMD.decode().strip()}")
ser.write(START_CMD)

# Metadata
profile_begin_by_axis = {0: {}, 1: {}}
profile_t0_by_axis = {0: {}, 1: {}}
t0_info_by_axis = {0: None, 1: None}

# Data grouped by axis
raw_scans_all = {0: [], 1: []}         # repeated scans only 1..10
processed_scans_all = {0: [], 1: []}   # processed repeated scans only 1..10
initial_scan0_by_axis = {0: None, 1: None}

# Current in-progress scan
cur_axis = None
cur_scan_no = None
cur_t_ms = []
cur_deg = []
cur_stage = []
cur_raw = []
cur_v = []
cur_p_mw = []

profile_done = False
empty_count = 0


def reset_current_scan():
    global cur_axis, cur_scan_no, cur_t_ms, cur_deg, cur_stage, cur_raw, cur_v, cur_p_mw
    cur_axis = None
    cur_scan_no = None
    cur_t_ms = []
    cur_deg = []
    cur_stage = []
    cur_raw = []
    cur_v = []
    cur_p_mw = []


def finalize_current_scan():
    global initial_scan0_by_axis

    if cur_axis is None or cur_scan_no is None or len(cur_t_ms) == 0:
        reset_current_scan()
        return

    scan = {
        "axis": cur_axis,
        "scan_no": cur_scan_no,
        "t_ms": np.array(cur_t_ms, dtype=float),
        "deg": np.array(cur_deg, dtype=float),
        "stage": np.array(cur_stage, dtype=int),
        "raw": np.array(cur_raw, dtype=int),
        "v": np.array(cur_v, dtype=float),
        "p_mw": np.array(cur_p_mw, dtype=float),
    }

    axis_dir = os.path.join(run_dir, f"axis_{cur_axis + 1}")
    ensure_dir(axis_dir)

    # Keep initial scan 0 for T0 visualization only
    if cur_scan_no == 0:
        initial_scan0_by_axis[cur_axis] = scan
        save_raw_scan_csv(scan, os.path.join(axis_dir, f"axis{cur_axis+1}_scan0_raw.csv"))

    # Repeated scans 1..10 are the ones we process/save/average
    elif REPEATED_SCAN_MIN <= cur_scan_no <= REPEATED_SCAN_MAX:
        raw_scans_all[cur_axis].append(scan)

        save_raw_scan_csv(
            scan,
            os.path.join(axis_dir, f"axis{cur_axis+1}_scan{cur_scan_no}_raw.csv")
        )

        result = process_scan(scan["t_ms"], scan["deg"], scan["p_mw"], scan["v"])
        if result is not None:
            processed_scans_all[cur_axis].append(result)

            save_processed_scan_csv(
                cur_axis,
                cur_scan_no,
                result,
                os.path.join(axis_dir, f"axis{cur_axis+1}_scan{cur_scan_no}_processed.csv")
            )

            save_scan_plots(
                cur_axis,
                cur_scan_no,
                result,
                axis_dir,
                t0_info=t0_info_by_axis[cur_axis]
            )

            sigma_txt = "None" if result["sigma"] is None else f"{result['sigma']:.4f}"
            w4_txt = "None" if result["width_4sigma"] is None else f"{result['width_4sigma']:.4f}"
            print(
                f"Processed axis={cur_axis} scan={cur_scan_no} "
                f"sigma={sigma_txt} width_4sigma={w4_txt}"
            )
        else:
            print(f"Skipped processing axis={cur_axis} scan={cur_scan_no}: too few usable points")

            fig, ax = plt.subplots(figsize=(10, 5))
            ax.plot(scan["deg"], scan["p_mw"], label="Raw power vs deg")
            ax.set_xlabel("Angle (deg)")
            ax.set_ylabel("Power (mW)")
            ax.set_title(f"Axis {cur_axis+1} Scan {cur_scan_no} - Raw Fallback")
            ax.grid(True)
            ax.legend()
            fig.savefig(
                os.path.join(axis_dir, f"axis{cur_axis+1}_scan{cur_scan_no}_raw_fallback.png"),
                dpi=200, bbox_inches="tight"
            )
            plt.close(fig)

    reset_current_scan()


try:
    while not profile_done and empty_count < EMPTY_LIMIT:
        raw_line = ser.readline()

        if not raw_line:
            empty_count += 1
            continue

        empty_count = 0

        try:
            line = raw_line.decode(errors="ignore").strip()
        except Exception:
            continue

        if not line:
            continue

        print(line)

        # ------------------------------------------
        # BM point lines
        # ------------------------------------------
        bm = parse_bm(line)
        if bm is not None:
            axis = bm["axis"]
            scan_no = bm["scan"]

            # New scan started
            if cur_axis is None:
                cur_axis = axis
                cur_scan_no = scan_no
            elif axis != cur_axis or scan_no != cur_scan_no:
                finalize_current_scan()
                cur_axis = axis
                cur_scan_no = scan_no

            cur_t_ms.append(bm["t_ms"])
            cur_deg.append(bm["deg"])
            cur_stage.append(bm["stage"])
            cur_raw.append(bm["raw"])
            cur_v.append(bm["v"])
            cur_p_mw.append(bm["p_mw"])
            continue

        # ------------------------------------------
        # STM32 key metadata
        # ------------------------------------------
        if line.startswith("PROFILE_BEGIN"):
            d = parse_keyvals(line)
            axis = safe_int(d, "axis", None)
            if axis in (0, 1):
                profile_begin_by_axis[axis] = d
            continue

        if line.startswith("PROFILE_T0_ENC"):
            d = parse_keyvals(line)
            axis = safe_int(d, "axis", None)
            if axis in (0, 1):
                profile_t0_by_axis[axis] = d
            continue

        if line.startswith("PROFILE_SCAN_DONE"):
            # no action needed here; BM stream boundary handles actual scan finalization
            continue

        if line.startswith("PROFILE_AXIS_DONE"):
            continue

        if line.startswith("PROFILE_DONE"):
            finalize_current_scan()
            profile_done = True
            break

        if line.startswith("PROFILE_T0_FAIL"):
            print("WARNING:", line)
            continue

        if line.startswith("ABORT") or line.startswith("ERROR"):
            print("WARNING:", line)
            continue

    # Final flush if any last scan exists
    finalize_current_scan()

finally:
    ser.close()

# ============================================================
# Build T0 overlay info and save initial scan-0 plots
# ============================================================
for axis in (0, 1):
    axis_dir = os.path.join(run_dir, f"axis_{axis + 1}")
    ensure_dir(axis_dir)

    if profile_t0_by_axis[axis]:
        idx = safe_int(profile_t0_by_axis[axis], "idx", None)
        t0_meta = {"idx": idx} if idx is not None else None
    else:
        t0_meta = None

    t0_info_by_axis[axis] = build_t0_info_from_scan(initial_scan0_by_axis[axis], t0_meta)

    if initial_scan0_by_axis[axis] is not None:
        save_initial_t0_scan_plot(
            axis,
            initial_scan0_by_axis[axis],
            t0_info_by_axis[axis],
            axis_dir
        )

# ============================================================
# Save per-axis combined raw CSV, save average, popup averages
# ============================================================
for axis in (0, 1):
    axis_dir = os.path.join(run_dir, f"axis_{axis + 1}")
    ensure_dir(axis_dir)

    if raw_scans_all[axis]:
        save_axis_combined_raw_csv(
            axis,
            raw_scans_all[axis],
            os.path.join(axis_dir, f"axis{axis+1}_all_repeated_raw.csv")
        )
 
    avg_result = average_processed_scans(processed_scans_all[axis])

    if avg_result is not None:
        save_average_csv(
            axis,
            avg_result,
            os.path.join(axis_dir, f"axis{axis+1}_average_processed.csv")
        )
        save_average_plots(axis, avg_result, axis_dir, t0_info=t0_info_by_axis[axis])
        popup_average_only(axis, avg_result, t0_info=t0_info_by_axis[axis])

        sigma_txt = "None" if avg_result["sigma"] is None else f"{avg_result['sigma']:.4f}"
        w4_txt = "None" if avg_result["width_4sigma"] is None else f"{avg_result['width_4sigma']:.4f}"
        print(f"Axis {axis+1} average: sigma={sigma_txt}, width_4sigma={w4_txt}")
    else:
        print(f"Axis {axis+1}: no average generated")

print(f"\nSaved all results to: {run_dir}")
plt.show()