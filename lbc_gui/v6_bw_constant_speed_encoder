def ensure_dir(path: str) -> None:
    os.makedirs(path, exist_ok=True)


def parse_keyvals(line: str):
    out = {}
    parts = line.strip().split(",")
    for p in parts[1:]:
        if "=" in p:
            k, v = p.split("=", 1)
            out[k.strip()] = v.strip()
    return out


def safe_float(d, key, default=None):
    try:
        return float(d[key])
    except Exception:
        return default


def safe_int(d, key, default=None):
    try:
        return int(float(d[key]))
    except Exception:
        return default


def parse_bm(line: str):
    """
    STM32 format:
    BM,axis,scan,t_ms,deg,stage,raw,v,p_mw
    """
    try:
        parts = line.strip().split(",")
        if len(parts) != 9:
            return None
        if parts[0] != "BM":
            return None

        return {
            "axis": int(parts[1]),
            "scan": int(parts[2]),
            "t_ms": float(parts[3]),
            "deg": float(parts[4]),
            "stage": int(parts[5]),
            "raw": int(parts[6]),
            "v": float(parts[7]),
            "p_mw": float(parts[8]),
        }
    except Exception:
        return None


def moving_average(y, w):
    y = np.asarray(y, dtype=float)
    if len(y) < max(3, w):
        return y.copy()
    if w % 2 == 0:
        w += 1
    pad = w // 2
    ypad = np.pad(y, (pad, pad), mode="edge")
    k = np.ones(w, dtype=float) / float(w)
    return np.convolve(ypad, k, mode="valid")


def normalize_01(y):
    y = np.asarray(y, dtype=float)
    y0 = np.min(y)
    y1 = np.max(y)
    if abs(y1 - y0) <= 1e-12:
        return np.zeros_like(y)
    return (y - y0) / (y1 - y0)


def robust_edge_levels(sig, frac=EDGE_FRAC):
    sig = np.asarray(sig, dtype=float)
    n = len(sig)
    k = max(3, int(frac * n))
    left = np.median(sig[:k])
    right = np.median(sig[-k:])
    return left, right


def is_mostly_monotonic(y):
    y = np.asarray(y, dtype=float)
    if len(y) < 8:
        return True

    dy = np.diff(y)
    if np.all(np.abs(dy) < 1e-12):
        return True

    total_var = np.sum(np.abs(dy)) + 1e-12
    end_to_end = abs(y[-1] - y[0])
    mono_score = end_to_end / total_var

    i_peak = int(np.argmax(y))
    i_valley = int(np.argmin(y))
    interior_peak = (0 < i_peak < len(y) - 1)
    interior_valley = (0 < i_valley < len(y) - 1)

    if mono_score < MONO_SCORE_THRESH and (interior_peak or interior_valley):
        return False

    return True


def knife_from_monotonic_power(p_s):
    left, right = robust_edge_levels(p_s)

    P = (p_s - left) / (right - left + 1e-12)
    P = np.clip(P, 0.0, 1.0)

    k = max(3, len(P) // 10)
    if np.mean(P[:k]) < np.mean(P[-k:]):
        P = 1.0 - P

    P = moving_average(P, MA_W_P)
    P = np.clip(P, 0.0, 1.0)
    return P


def profile_from_hump_power(x_mm, p_s):
    left, right = robust_edge_levels(p_s)
    baseline = min(left, right)

    prof = p_s - baseline
    prof = np.maximum(prof, 0.0)
    prof = moving_average(prof, MA_W_D)
    prof = np.maximum(prof, 0.0)

    if np.max(prof) > 0:
        prof = np.where(prof >= 0.03 * np.max(prof), prof, 0.0)

    dx = float(np.median(np.diff(x_mm)))
    P_rise = np.cumsum(prof) * dx
    P_rise = normalize_01(P_rise)

    P = 1.0 - P_rise
    P = moving_average(P, MA_W_P)
    P = np.clip(P, 0.0, 1.0)

    return P, prof


def crossing_x_at_level(x, y, level=0.5):
    x = np.asarray(x, dtype=float)
    y = np.asarray(y, dtype=float)

    if len(x) < 2:
        return 0.0

    s = y - level
    idx = np.where(np.signbit(s[:-1]) != np.signbit(s[1:]))[0]
    if len(idx) == 0:
        return float(x[np.argmin(np.abs(s))])

    i = idx[0]
    x0, x1 = x[i], x[i + 1]
    y0, y1 = y[i], y[i + 1]

    if abs(y1 - y0) < 1e-12:
        return float(x0)

    return float(x0 + (level - y0) * (x1 - x0) / (y1 - y0))


def weighted_stats_from_profile(x, prof):
    x = np.asarray(x, dtype=float)
    prof = np.asarray(prof, dtype=float)

    prof = np.maximum(prof, 0.0)
    s = float(np.sum(prof))
    if s <= 0 or len(x) < 3:
        return None, None, None

    mu = float(np.sum(x * prof) / s)
    var = float(np.sum(prof * (x - mu) ** 2) / s)
    sigma = float(np.sqrt(max(var, 0.0)))
    width_4sigma = 4.0 * sigma
    return mu, sigma, width_4sigma


def crop_main_lobe(x, profile, half_win_mm=PROFILE_HALF_WIN_MM, thresh_frac=PROFILE_THRESH_FRAC):
    x = np.asarray(x, dtype=float)
    profile = np.asarray(profile, dtype=float)

    if len(x) < 5:
        return x, profile

    profile = np.maximum(profile, 0.0)
    i_peak = int(np.argmax(profile))
    x_peak = x[i_peak]
    p_peak = profile[i_peak]

    if p_peak <= 0:
        return x, profile

    keep = (x >= (x_peak - half_win_mm)) & (x <= (x_peak + half_win_mm))
    x_c = x[keep]
    p_c = profile[keep]

    if len(x_c) < 5:
        return x, profile

    thresh = thresh_frac * np.max(p_c)
    p_c = np.where(p_c >= thresh, p_c, 0.0)
    return x_c, p_c


def process_scan(t_ms, deg, p_mw, v=None):
    t_ms = np.asarray(t_ms, dtype=float)
    deg = np.asarray(deg, dtype=float)
    p_mw = np.asarray(p_mw, dtype=float)

    if len(t_ms) < 5:
        return None

    t_s = (t_ms - t_ms[0]) / 1000.0
    theta_rad = np.deg2rad(deg - deg[0])
    x_mm = R_MM * theta_rad

    order = np.argsort(x_mm)
    x_mm = x_mm[order]
    t_s = t_s[order]
    deg = deg[order]
    p_mw = p_mw[order]

    if v is None or len(v) != len(p_mw):
        v_s = p_mw.copy()
    else:
        v_s = moving_average(np.asarray(v, dtype=float)[order], MA_W_V)

    p_s = p_mw.copy()

    # Remove duplicate / nearly duplicate x values
    keep = np.ones(len(x_mm), dtype=bool)
    keep[1:] = np.abs(np.diff(x_mm)) > 1e-9

    x_mm = x_mm[keep]
    t_s = t_s[keep]
    deg = deg[keep]
    p_s = p_s[keep]
    v_s = v_s[keep]

    if len(x_mm) < 5:
        return None

    dx_all = np.diff(x_mm)
    dx_nonzero = dx_all[np.abs(dx_all) > 1e-9]

    if len(dx_nonzero) == 0:
        return None

    dx = float(np.median(dx_nonzero))

    monotonic_mode = is_mostly_monotonic(p_s)

    if monotonic_mode:
        P = knife_from_monotonic_power(p_s)
        dPdx = np.gradient(P, x_mm)
        profile_full = -dPdx
        profile_full = profile_full - np.min(profile_full)
        profile_full = np.maximum(profile_full, 0.0)
        profile_full = moving_average(profile_full, MA_W_D)
        profile_full = np.maximum(profile_full, 0.0)
    else:
        P, profile_full = profile_from_hump_power(x_mm, p_s)

    if np.max(profile_full) > 0:
        profile_full = np.where(profile_full >= 0.04 * np.max(profile_full), profile_full, 0.0)

    x_prof, profile = crop_main_lobe(x_mm, profile_full)
    mu, sigma, width_4sigma = weighted_stats_from_profile(x_prof, profile)

    x_center = crossing_x_at_level(x_mm, P, 0.5)
    x_mm_rel = x_mm - x_center

    if mu is not None:
        x_prof_centered = x_prof - mu
    else:
        x_prof_centered = x_prof - x_center

    return {
        "t_s": t_s,
        "x_mm": x_mm_rel,
        "deg": deg,
        "v_s": v_s,
        "p_mw": p_s,
        "P": P,
        "profile_full": profile_full,
        "x_prof": x_prof_centered,
        "profile": profile,
        "mu": mu,
        "sigma": sigma,
        "width_4sigma": width_4sigma,
        "x_center": x_center,
        "mode": "knife_edge" if monotonic_mode else "profile_integrated",
    }

def average_processed_scans(results):
    if not results:
        return None
    if len(results) == 1:
        return results[0]

    x0 = max(r["x_mm"][0] for r in results)
    x1 = min(r["x_mm"][-1] for r in results)
    if x1 <= x0:
        return None

    n = min(len(r["x_mm"]) for r in results)
    x_common = np.linspace(x0, x1, n)

    v_stack = []
    p_stack = []
    P_stack = []
    prof_stack = []
    t_stack = []

    for r in results:
        v_stack.append(np.interp(x_common, r["x_mm"], r["v_s"]))
        p_stack.append(np.interp(x_common, r["x_mm"], r["p_mw"]))
        P_stack.append(np.interp(x_common, r["x_mm"], r["P"]))
        prof_stack.append(np.interp(x_common, r["x_mm"], r["profile_full"]))
        t_stack.append(np.interp(x_common, r["x_mm"], r["t_s"]))

    v_avg = np.mean(np.vstack(v_stack), axis=0)
    p_avg = np.mean(np.vstack(p_stack), axis=0)
    P_avg = np.mean(np.vstack(P_stack), axis=0)
    prof_full_avg = np.mean(np.vstack(prof_stack), axis=0)
    t_avg = np.mean(np.vstack(t_stack), axis=0)

    x_prof, prof_avg = crop_main_lobe(x_common, prof_full_avg)
    mu, sigma, width_4sigma = weighted_stats_from_profile(x_prof, prof_avg)
    x_prof_centered = x_prof - mu if mu is not None else x_prof

    return {
        "t_s": t_avg,
        "x_mm": x_common,
        "deg": None,
        "v_s": v_avg,
        "p_mw": p_avg,
        "P": P_avg,
        "profile_full": prof_full_avg,
        "x_prof": x_prof_centered,
        "profile": prof_avg,
        "mu": mu,
        "sigma": sigma,
        "width_4sigma": width_4sigma,
        "x_center": 0.0,
        "mode": "avg",
    }


def add_t0_overlay(ax, t0_info, axis="x"):
    if t0_info is None:
        return

    if axis == "x":
        xpos = t0_info["x_mm"]
        ax.axvline(xpos, linestyle="--", linewidth=2, label=f"T0 = {xpos:.3f} mm")
    elif axis == "deg":
        xpos = t0_info["deg"]
        ax.axvline(xpos, linestyle="--", linewidth=2, label=f"T0 = {xpos:.3f} deg")


def build_t0_info_from_scan(scan0, t0_meta):
    if scan0 is None or t0_meta is None:
        return None

    idx = t0_meta.get("idx", None)
    if idx is None:
        return None
    if idx < 0 or idx >= len(scan0["t_ms"]):
        return None

    deg0 = scan0["deg"][0]
    deg_t0 = float(scan0["deg"][idx] - deg0)
    x_t0 = float(R_MM * np.deg2rad(deg_t0))
    p_t0 = float(scan0["p_mw"][idx])

    return {
        "idx": int(idx),
        "t_ms": float(scan0["t_ms"][idx]),
        "deg": deg_t0,
        "x_mm": x_t0,
        "p_mw": p_t0,
    }


def save_raw_scan_csv(scan, out_csv):
    n = len(scan["t_ms"])
    data = np.column_stack((
        np.full(n, scan["axis"], dtype=int),
        np.full(n, scan["scan_no"], dtype=int),
        np.arange(n, dtype=int),
        scan["t_ms"],
        scan["deg"],
        scan["stage"],
        scan["raw"],
        scan["v"],
        scan["p_mw"],
    ))
    np.savetxt(
        out_csv,
        data,
        delimiter=",",
        header="axis,scan_no,point_idx,t_ms,deg,stage,raw,v,p_mw",
        comments="",
        fmt=["%d", "%d", "%d", "%.6f", "%.6f", "%d", "%d", "%.6f", "%.6f"],
    )


def save_processed_scan_csv(axis, scan_no, result, out_csv):
    n1 = len(result["x_mm"])
    n2 = len(result["x_prof"])
    with open(out_csv, "w", encoding="utf-8") as f:
        f.write(f"# axis,{axis}\n")
        f.write(f"# scan_no,{scan_no}\n")
        f.write(f"# mode,{result['mode']}\n")
        f.write(f"# sigma_mm,{result['sigma']}\n")
        f.write(f"# width_4sigma_mm,{result['width_4sigma']}\n")
        f.write("x_mm,v_s,p_mw_smooth,P,profile_x_mm,beam_profile\n")
        for i in range(max(n1, n2)):
            c1 = c2 = c3 = c4 = c5 = c6 = ""
            if i < n1:
                c1 = f"{result['x_mm'][i]:.6f}"
                c2 = f"{result['v_s'][i]:.6f}"
                c3 = f"{result['p_mw'][i]:.6f}"
                c4 = f"{result['P'][i]:.6f}"
            if i < n2:
                c5 = f"{result['x_prof'][i]:.6f}"
                c6 = f"{result['profile'][i]:.6f}"
            f.write(f"{c1},{c2},{c3},{c4},{c5},{c6}\n")


def save_scan_plots(axis, scan_no, result, out_dir, t0_info=None):
    axis_label = axis + 1

    fig1, ax1 = plt.subplots(figsize=(10, 5))
    ax1.plot(result["x_mm"], result["p_mw"], label="Power (mW)")
    ax1.plot(result["x_mm"], result["P"], label="Normalized knife-edge")
    add_t0_overlay(ax1, t0_info, axis="x")
    ax1.set_xlabel("Position x (mm)")
    ax1.set_ylabel("Power / normalized power")
    ax1.set_title(f"Axis {axis_label} Scan {scan_no} - Knife-edge / Power")
    ax1.grid(True)
    ax1.legend()
    if result["sigma"] is not None:
        ax1.text(
            0.02, 0.98,
            f"σ = {result['sigma']:.3f} mm\n"
            f"4σ = {result['width_4sigma']:.3f} mm\n"
            f"mode = {result['mode']}",
            transform=ax1.transAxes,
            va="top", ha="left"
        )
    fig1.savefig(
        os.path.join(out_dir, f"axis{axis_label}_scan{scan_no}_knifeedge.png"),
        dpi=200, bbox_inches="tight"
    )
    if POPUP_EACH_SCAN:
        plt.show(block=False)
    plt.close(fig1)

    fig2, ax2 = plt.subplots(figsize=(10, 5))
    ax2.plot(result["x_prof"], result["profile"], label="Beam profile")
    if t0_info is not None:
        ax2.axvline(0.0, linestyle="--", linewidth=2, label="Beam center ref")
    ax2.set_xlabel("Position relative to centroid (mm)")
    ax2.set_ylabel("Profile amplitude")
    ax2.set_title(f"Axis {axis_label} Scan {scan_no} - Beam Profile")
    ax2.grid(True)
    ax2.legend()
    if result["sigma"] is not None:
        ax2.text(
            0.02, 0.98,
            f"σ = {result['sigma']:.3f} mm\n"
            f"4σ = {result['width_4sigma']:.3f} mm",
            transform=ax2.transAxes,
            va="top", ha="left"
        )
    fig2.savefig(
        os.path.join(out_dir, f"axis{axis_label}_scan{scan_no}_profile.png"),
        dpi=200, bbox_inches="tight"
    )
    if POPUP_EACH_SCAN:
        plt.show(block=False)
    plt.close(fig2)


def save_initial_t0_scan_plot(axis, scan0, t0_info, out_dir, smooth_win=9):
    if scan0 is None:
        return

    axis_label = axis + 1

    t_ms = np.asarray(scan0["t_ms"], dtype=float)
    deg = np.asarray(scan0["deg"], dtype=float)
    p_mw = np.asarray(scan0["p_mw"], dtype=float)

    if len(t_ms) < 3:
        return

    theta_deg = deg - deg[0]
    theta_rad = np.deg2rad(theta_deg)
    x_mm = R_MM * theta_rad

    smooth_win = max(1, int(smooth_win))
    if smooth_win % 2 == 0:
        smooth_win += 1

    kernel = np.ones(smooth_win, dtype=float) / smooth_win
    p_smooth = np.convolve(p_mw, kernel, mode="same")

    if len(x_mm) >= 3 and np.all(np.diff(x_mm) != 0):
        dpdx = np.gradient(p_smooth) / np.gradient(x_mm)
        abs_dpdx = np.abs(dpdx)
    else:
        abs_dpdx = np.zeros_like(p_smooth)

    x_t0 = t0_info["x_mm"] if t0_info is not None else None
    deg_t0 = t0_info["deg"] if t0_info is not None else None
    t0_ms = t0_info["t_ms"] if t0_info is not None else None
    p_t0 = t0_info["p_mw"] if t0_info is not None else None

    fig, axs = plt.subplots(3, 1, figsize=(10, 12))

    axs[0].plot(theta_deg, p_mw, label="Power (mW)")
    axs[0].plot(theta_deg, p_smooth, label="Smoothed Power")
    if deg_t0 is not None:
        axs[0].axvline(deg_t0, linestyle="--", linewidth=2, label=f"STM32 T0 = {deg_t0:.3f} deg")
    axs[0].set_xlabel("Angle (deg)")
    axs[0].set_ylabel("Power (mW)")
    axs[0].set_title(f"Axis {axis_label} Initial Scan 0 - Power vs Angle")
    axs[0].grid(True)
    axs[0].legend()

    axs[1].plot(x_mm, p_mw, label="Power (mW)")
    axs[1].plot(x_mm, p_smooth, label="Smoothed Power")
    if x_t0 is not None:
        axs[1].axvline(x_t0, linestyle="--", linewidth=2, label=f"STM32 T0 = {x_t0:.3f} mm")
        if p_t0 is not None:
            axs[1].plot(x_t0, p_t0, "ro", label="STM32 T0 point")
    axs[1].set_xlabel("Position (mm)")
    axs[1].set_ylabel("Power (mW)")
    axs[1].set_title(f"Axis {axis_label} Initial Scan 0 - Power vs Position")
    axs[1].grid(True)
    axs[1].legend()

    axs[2].plot(x_mm, abs_dpdx, label="|dP/dx|")
    if x_t0 is not None:
        axs[2].axvline(x_t0, linestyle="--", linewidth=2, label=f"STM32 T0 = {x_t0:.3f} mm")
    axs[2].set_xlabel("Position (mm)")
    axs[2].set_ylabel("Absolute derivative")
    axs[2].set_title(f"Axis {axis_label} Initial Scan 0 - Derivative vs Position")
    axs[2].grid(True)
    axs[2].legend()

    if t0_info is not None:
        txt = (
            f"T0 index = {t0_info.get('idx', 'N/A')}\n"
            f"T0 = {t0_ms:.3f} ms\n"
            f"T0 = {deg_t0:.3f} deg\n"
            f"T0 = {x_t0:.3f} mm"
        )
        if p_t0 is not None:
            txt += f"\nT0 power = {p_t0:.6f} mW"

        axs[1].text(
            0.02, 0.98,
            txt,
            transform=axs[1].transAxes,
            va="top", ha="left"
        )

    fig.tight_layout()
    fig.savefig(
        os.path.join(out_dir, f"axis{axis_label}_initial_scan0_t0.png"),
        dpi=200, bbox_inches="tight"
    )
    plt.close(fig)


