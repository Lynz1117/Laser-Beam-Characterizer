# ============================================================
# Main acquisition
# ============================================================
timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
run_dir = os.path.join(SAVE_ROOT, f"profile_run_{timestamp}")
ensure_dir(run_dir)

ser = serial.Serial(PORT, BAUD, timeout=SERIAL_TIMEOUT_S)
ser.reset_input_buffer()
ser.reset_output_buffer()

print(f"Opening {PORT} @ {BAUD}")
print(f"Sending command: {START_CMD.decode().strip()}")
ser.write(START_CMD)

# Metadata from STM32 prints
profile_begin_by_axis = {0: {}, 1: {}}
profile_t0_by_axis = {0: {}, 1: {}}
t0_info_by_axis = {0: None, 1: None}

# Raw repeated scans grouped by axis
raw_scans_all = {0: [], 1: []}
processed_scans_all = {0: [], 1: []}

initial_scan0_by_axis = {0: None, 1: None}

# Current in-progress scan
cur_axis = None
cur_scan_no = None
cur_t_ms = []
cur_deg = []
cur_stage = []
cur_raw = []
cur_v = []
cur_p_mw = []

profile_done = False
empty_count = 0


def finalize_current_scan():
    global cur_axis, cur_scan_no, cur_t_ms, cur_deg, cur_stage, cur_raw, cur_v, cur_p_mw
    global initial_scan0_by_axis

    if cur_axis is None or cur_scan_no is None or len(cur_t_ms) == 0:
        cur_axis = None
        cur_scan_no = None
        cur_t_ms = []
        cur_deg = []
        cur_stage = []
        cur_raw = []
        cur_v = []
        cur_p_mw = []
        return

    scan = {
        "axis": cur_axis,
        "scan_no": cur_scan_no,
        "t_ms": np.array(cur_t_ms, dtype=float),
        "deg": np.array(cur_deg, dtype=float),
        "stage": np.array(cur_stage, dtype=int),
        "raw": np.array(cur_raw, dtype=int),
        "v": np.array(cur_v, dtype=float),
        "p_mw": np.array(cur_p_mw, dtype=float),
    }

    # KEEP scan 0 so we can plot where T0 was found from the initial scan
    if cur_scan_no == 0:
        initial_scan0_by_axis[cur_axis] = scan

    # Keep existing repeated scan handling
    if REPEATED_SCAN_MIN <= cur_scan_no <= REPEATED_SCAN_MAX:
        raw_scans_all[cur_axis].append(scan)

        result = process_scan(scan["t_ms"], scan["deg"], scan["p_mw"], scan["v"])
        if result is not None:
            processed_scans_all[cur_axis].append({
                "scan_no": cur_scan_no,
                "result": result
            })

    cur_axis = None
    cur_scan_no = None
    cur_t_ms = []
    cur_deg = []
    cur_stage = []
    cur_raw = []
    cur_v = []
    cur_p_mw = []


while not profile_done:
    line = ser.readline().decode(errors="ignore").strip()

    if not line:
        empty_count += 1
        if empty_count > EMPTY_LIMIT:
            print("Timed out waiting for STM32 profile output.")
            break
        continue

    empty_count = 0
    print(line)

    if line == "BM_DONE":
        finalize_current_scan()
        continue

    if line.startswith("PROFILE_DONE"):
        finalize_current_scan()
        profile_done = True
        continue

    if line.startswith("PROFILE_ABORT"):
        finalize_current_scan()
        break

    if line.startswith("PROFILE_BEGIN"):
        kv = parse_keyvals(line)
        axis = safe_int(kv, "axis", None)
        if axis in (0, 1):
            profile_begin_by_axis[axis] = kv
        continue

    if line.startswith("PROFILE_T0"):
        kv = parse_keyvals(line)
        axis = safe_int(kv, "axis", None)
        if axis in (0, 1):
            profile_t0_by_axis[axis] = kv
        continue

    if line.startswith("PROFILE_TIMING") or line.startswith("PROFILE_SCAN_") or line.startswith("PROFILE_AXIS_DONE"):
        continue

    bm = parse_bm(line)
    if bm is None:
        continue

    axis = bm["axis"]
    scan_no = bm["scan"]

    if cur_axis is None:
        cur_axis = axis
        cur_scan_no = scan_no
    elif axis != cur_axis or scan_no != cur_scan_no:
        finalize_current_scan()
        cur_axis = axis
        cur_scan_no = scan_no

    cur_t_ms.append(bm["t_ms"])
    cur_deg.append(bm["deg"])
    cur_stage.append(bm["stage"])
    cur_raw.append(bm["raw"])
    cur_v.append(bm["v"])
    cur_p_mw.append(bm["p_mw"])

ser.close()

# ============================================================
# Compute and print T0 per axis from STM32 metadata
# ============================================================
for axis in (0, 1):
    begin_kv = profile_begin_by_axis[axis]
    t0_kv = profile_t0_by_axis[axis]

    omega = safe_float(begin_kv, "omega", None)
    t0_s = safe_float(t0_kv, "t0_s", None)
    t0_ms = safe_float(t0_kv, "t0_ms", None)
    t0_idx = safe_int(t0_kv, "idx", None)
    t0_p_mw = safe_float(t0_kv, "p_mw", None)

    if t0_ms is not None:
        t0_s_calc = t0_ms / 1000.0
    elif t0_s is not None:
        t0_s_calc = t0_s
    else:
        t0_s_calc = None

    if omega is not None and t0_s_calc is not None:
        t0_deg = np.degrees(omega * t0_s_calc)
        t0_x_mm = R_MM * omega * t0_s_calc

        t0_info_by_axis[axis] = {
            "idx": t0_idx,
            "t_s": t0_s_calc,
            "t_ms": t0_s_calc * 1000.0,
            "deg": t0_deg,
            "x_mm": t0_x_mm,
            "p_mw": t0_p_mw,
        }

        print(f"\n=== AXIS {axis + 1} T0 ===")
        if t0_idx is not None:
            print(f"T0 index:         {t0_idx}")
        print(f"T0 time (s):      {t0_s_calc:.6f}")
        print(f"T0 time (ms):     {t0_s_calc * 1000.0:.3f}")
        print(f"T0 angle (deg):   {t0_deg:.3f}")
        print(f"T0 position (mm): {t0_x_mm:.4f}")
        if t0_p_mw is not None:
            print(f"T0 power (mW):    {t0_p_mw:.6f}")
    else:
        print(f"\n=== AXIS {axis + 1} T0 ===")
        print("T0 information not available from STM32 prints.")
        
# ============================================================
# Save / show initial scan 0 T0 plots
# ============================================================
for axis in (0, 1):
    axis_label = axis + 1
    axis_dir = os.path.join(run_dir, f"axis_{axis_label}")
    ensure_dir(axis_dir)

    scan0 = initial_scan0_by_axis[axis]
    t0_info = t0_info_by_axis[axis]

    if scan0 is not None:
        save_raw_scan_csv(
            scan0,
            os.path.join(axis_dir, f"axis{axis_label}_initial_scan0_raw.csv")
        )

        save_initial_t0_scan_plot(
            axis=axis,
            scan0=scan0,
            t0_info=t0_info,
            out_dir=axis_dir,
            smooth_win=9
        )

# ============================================================
# Save everything
# ============================================================
for axis in (0, 1):
    axis_label = axis + 1
    axis_dir = os.path.join(run_dir, f"axis_{axis_label}")
    ensure_dir(axis_dir)

    raw_scans = raw_scans_all[axis]
    proc_scans = processed_scans_all[axis]

    print(f"\nAxis {axis_label}: captured {len(raw_scans)} repeated scans")

    if raw_scans:
        save_axis_combined_raw_csv(
            axis,
            raw_scans,
            os.path.join(axis_dir, f"axis{axis_label}_all_raw_scans.csv")
        )

    proc_by_scan = {item["scan_no"]: item["result"] for item in proc_scans}

    for scan in raw_scans:
        scan_no = int(scan["scan_no"])

        save_raw_scan_csv(
            scan,
            os.path.join(axis_dir, f"axis{axis_label}_scan{scan_no}_raw.csv")
        )

        if scan_no in proc_by_scan:
            result = proc_by_scan[scan_no]

            save_processed_scan_csv(
                axis,
                scan_no,
                result,
                os.path.join(axis_dir, f"axis{axis_label}_scan{scan_no}_processed.csv")
            )

            save_scan_plots(axis, scan_no, result, axis_dir, t0_info_by_axis[axis])

    only_results = [item["result"] for item in proc_scans]
    avg_result = average_processed_scans(only_results)

    if avg_result is not None:
        save_average_csv(
            axis,
            avg_result,
            os.path.join(axis_dir, f"axis{axis_label}_average.csv")
        )

        save_average_plots(axis, avg_result, axis_dir)

        print(
            f"Axis {axis_label} average: "
            f"sigma = {avg_result['sigma']:.6f} mm, "
            f"4sigma width = {avg_result['width_4sigma']:.6f} mm"
        )

        if t0_info_by_axis[axis] is not None:
            print(
                f"Axis {axis_label} T0 summary: "
                f"x = {t0_info_by_axis[axis]['x_mm']:.4f} mm, "
                f"theta = {t0_info_by_axis[axis]['deg']:.3f} deg"
            )

        popup_average_only(axis, avg_result, t0_info=t0_info_by_axis[axis])
    else:
        print(f"Axis {axis_label}: no valid average result")

print(f"\nSaved all data to: {run_dir}")
plt.show()