def parse_keyvals(line: str):
    out = {}
    parts = line.strip().split(",")
    for p in parts[1:]:
        if "=" in p:
            k, v = p.split("=", 1)
            out[k.strip()] = v.strip()
    return out


def safe_float(d, key, default=None):
    try:
        return float(d[key])
    except Exception:
        return default


def safe_int(d, key, default=None):
    try:
        return int(float(d[key]))
    except Exception:
        return default


def parse_bm(line: str):
    """
    Expected STM32 format:
    BM,axis,scan,t_ms,deg,stage,raw,v,p_mw
    """
    try:
        parts = line.strip().split(",")
        if len(parts) != 9:
            return None
        if parts[0] != "BM":
            return None

        return {
            "axis": int(parts[1]),
            "scan": int(parts[2]),
            "t_ms": float(parts[3]),
            "deg": float(parts[4]),
            "stage": int(parts[5]),
            "raw": int(parts[6]),
            "v": float(parts[7]),
            "p_mw": float(parts[8]),
        }
    except Exception:
        return None

def add_t0_overlay(ax, t0_info, axis="x"):
