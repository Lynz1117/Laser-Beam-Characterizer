def save_axis_combined_raw_csv(axis, raw_scans, out_csv):
    with open(out_csv, "w", encoding="utf-8") as f:
        f.write("axis,scan_no,point_idx,t_ms,deg,stage,raw,v,p_mw\n")
        for scan in raw_scans:
            n = len(scan["t_ms"])
            for i in range(n):
                f.write(
                    f"{scan['axis']},{scan['scan_no']},{i},"
                    f"{scan['t_ms'][i]:.6f},{scan['deg'][i]:.6f},"
                    f"{scan['stage'][i]},{scan['raw'][i]},"
                    f"{scan['v'][i]:.6f},{scan['p_mw'][i]:.6f}\n"
                )


def save_average_csv(axis, avg_result, out_csv):
    n1 = len(avg_result["x_mm"])
    n2 = len(avg_result["x_prof"])
    with open(out_csv, "w", encoding="utf-8") as f:
        f.write(f"# axis,{axis}\n")
        f.write(f"# mode,{avg_result['mode']}\n")
        f.write(f"# sigma_mm,{avg_result['sigma']}\n")
        f.write(f"# width_4sigma_mm,{avg_result['width_4sigma']}\n")
        f.write(f"# mu_mm,{avg_result['mu']}\n")
        f.write("x_mm,v_s,p_mw_smooth,P,profile_x_mm,beam_profile\n")
        for i in range(max(n1, n2)):
            c1 = c2 = c3 = c4 = c5 = c6 = ""
            if i < n1:
                c1 = f"{avg_result['x_mm'][i]:.6f}"
                c2 = f"{avg_result['v_s'][i]:.6f}"
                c3 = f"{avg_result['p_mw'][i]:.6f}"
                c4 = f"{avg_result['P'][i]:.6f}"
            if i < n2:
                c5 = f"{avg_result['x_prof'][i]:.6f}"
                c6 = f"{avg_result['profile'][i]:.6f}"
            f.write(f"{c1},{c2},{c3},{c4},{c5},{c6}\n")


