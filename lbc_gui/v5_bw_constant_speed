    if axis == "x":
        xpos = t0_info["x_mm"]
        ax.axvline(xpos, linestyle="--", linewidth=2,
                   label=f"T0 = {xpos:.3f} mm")
    elif axis == "deg":
        xpos = t0_info["deg"]
        ax.axvline(xpos, linestyle="--", linewidth=2,
