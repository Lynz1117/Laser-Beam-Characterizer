def save_raw_scan_csv(scan, out_csv):
    n = len(scan["t_ms"])
    data = np.column_stack((
        np.full(n, scan["axis"], dtype=int),
        np.full(n, scan["scan_no"], dtype=int),
        np.arange(n, dtype=int),
        scan["t_ms"],
        scan["deg"],
        scan["stage"],
        scan["raw"],
        scan["v"],
        scan["p_mw"],
    ))
    np.savetxt(
        out_csv,
        data,
        delimiter=",",
        header="axis,scan_no,point_idx,t_ms,deg,stage,raw,v,p_mw",
        comments="",
        fmt=["%d", "%d", "%d", "%.6f", "%.6f", "%d", "%d", "%.6f", "%.6f"],
    )


def save_processed_scan_csv(axis, scan_no, result, out_csv):
    n1 = len(result["x_mm"])
    n2 = len(result["x_prof"])
    with open(out_csv, "w", encoding="utf-8") as f:
        f.write(f"# axis,{axis}\n")
        f.write(f"# scan_no,{scan_no}\n")
        f.write(f"# mode,{result['mode']}\n")
        f.write(f"# sigma_mm,{result['sigma']}\n")
        f.write(f"# width_4sigma_mm,{result['width_4sigma']}\n")
        f.write("x_mm,v_s,p_mw_smooth,P,profile_x_mm,beam_profile\n")
        for i in range(max(n1, n2)):
            c1 = c2 = c3 = c4 = c5 = c6 = ""
            if i < n1:
                c1 = f"{result['x_mm'][i]:.6f}"
                c2 = f"{result['v_s'][i]:.6f}"
                c3 = f"{result['p_mw'][i]:.6f}"
                c4 = f"{result['P'][i]:.6f}"
            if i < n2:
                c5 = f"{result['x_prof'][i]:.6f}"
                c6 = f"{result['profile'][i]:.6f}"
            f.write(f"{c1},{c2},{c3},{c4},{c5},{c6}\n")


