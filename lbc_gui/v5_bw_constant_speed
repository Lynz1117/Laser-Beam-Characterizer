    axs[0].legend()

    # Plot 2: like first script, power vs position
    axs[1].plot(x_mm, p_mw, label="Power (mW)")
    axs[1].plot(x_mm, p_smooth, label="Smoothed Power")
    if x_t0 is not None:
        axs[1].axvline(x_t0, linestyle="--", linewidth=2,
                       label=f"STM32 T0 = {x_t0:.3f} mm")
        if p_t0 is not None:
            axs[1].plot(x_t0, p_t0, "ro", label="STM32 T0 point")
    axs[1].set_xlabel("Position (mm)")
    axs[1].set_ylabel("Power (mW)")
    axs[1].set_title(f"Axis {axis_label} Initial Scan 0 - Power vs Position")
    axs[1].grid(True)
    axs[1].legend()

