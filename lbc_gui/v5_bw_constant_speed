    x_t0 = None
    deg_t0 = None
    t0_ms = None
    p_t0 = None

    if t0_info_by_axis is not None:
        x_t0 = t0_info["x_mm"]
        deg_t0 = t0_info["deg"]
        t0_ms = t0_info["t_ms"]
        p_t0 = t0_info.get("p_mw", None)

    fig, axs = plt.subplots(3, 1, figsize=(10, 12))

    # Plot 1: like first script, power vs angle
