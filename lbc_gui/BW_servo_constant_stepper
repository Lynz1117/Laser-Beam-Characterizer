# Main loop
# ============================================================
while plt.fignum_exists(fig.number):
    if sess.active and sess.last_bm_wall is not None:
        if (time.time() - sess.last_bm_wall) > STALL_TIMEOUT_S:
            print("[WARN] Stream stalled -> ABORT")
            if not USE_FAKE_SERIAL:
                try:
                    ser.write(ABORT_CMD)
                except Exception:
                    pass
            sess.active = False
            sess.abort = True
            status_text.set_text("Stalled")
            fig.canvas.draw_idle()

    if sess.active and sess.scan_start_wall is not None:
        if (time.time() - sess.scan_start_wall) > SCAN_TIMEOUT_S:
            print("[WARN] Scan timeout -> ABORT")
            if not USE_FAKE_SERIAL:
                try:
                    ser.write(ABORT_CMD)
                except Exception:
                    pass
            sess.active = False
            sess.abort = True
            status_text.set_text("Timeout")
            fig.canvas.draw_idle()

    got_any = False

    while True:
        try:
            line = rx_q.get_nowait()
            got_any = True
        except queue.Empty:
            break

        msg = parse_bm(line)
        if msg is None:
            continue

        if msg[0] in ("ACK_START", "ACK_ABORT"):
            continue

        if not sess.active or sess.abort:
            continue

        if msg[0] == "SCAN_BEGIN":
            _, scan_num = msg
            reset_current_scan_buffers()
            sess.cur_scan_num = scan_num
            sess.scan_start_wall = time.time()
            sess.last_bm_wall = time.time()
            status_text.set_text(
                f"Run {sess.done_runs + 1}/{sess.target_runs} — Position {scan_num}/20"
            )
            fig.canvas.draw_idle()

        elif msg[0] == "BM":
            _, scan_num, t_ms, deg, v = msg

            if sess.cur_scan_num is None:
                sess.cur_scan_num = scan_num

            sess.cur_t_ms.append(t_ms)
            sess.cur_deg.append(deg)
            sess.cur_v.append(v)
            sess.last_bm_wall = time.time()

        elif msg[0] == "BM_OLD":
            _, t_ms, deg, v = msg
            if sess.cur_scan_num is None:
                sess.cur_scan_num = 1
            sess.cur_t_ms.append(t_ms)
            sess.cur_deg.append(deg)
            sess.cur_v.append(v)
            sess.last_bm_wall = time.time()

        elif msg[0] == "DONE":
            _, scan_num = msg
            if scan_num is None:
                scan_num = sess.cur_scan_num if sess.cur_scan_num is not None else 1

            ok = finalize_one_scan(scan_num)
            if ok:
                print(f"[POSITION] {scan_num}/20 done.")

        elif msg[0] == "STEP_BEGIN":
            _, scan_num = msg
            status_text.set_text(
                f"Run {sess.done_runs + 1}/{sess.target_runs} — Moving after {scan_num}/20"
            )
            fig.canvas.draw_idle()

        elif msg[0] == "STEP_DONE":
            _, scan_num = msg
            pass

        elif msg[0] == "ALL_DONE":
            sess.done_runs += 1
            sess.all_runs.append(list(sess.current_run_results))

            print(f"[RUN] {sess.done_runs}/{sess.target_runs} done.")

            if sess.done_runs >= sess.target_runs:
                # For now, plot the last run
                plot_full_run(sess.current_run_results,
                              label="Single Run" if sess.target_runs == 1 else f"Run {sess.done_runs}")
                sess.active = False
                print("[RUN] Complete. Ready.")
            else:
                sess.current_run_results = []
                reset_current_scan_buffers()
                sess.scan_start_wall = None
                sess.last_bm_wall = None
                status_text.set_text(f"Collecting run {sess.done_runs + 1}/{sess.target_runs}...")
                fig.canvas.draw_idle()

                if USE_FAKE_SERIAL:
                    send_fake_scan()
                else:
                    try:
                        ser.write(START_CMD)
                    except Exception:
                        pass

            break

    if not got_any:
        plt.pause(0.01)
    else:
        plt.pause(0.001)

# Cleanup
stop_reader = True
if ser is not None:
    try:
        ser.close()
    except Exception:
        pass