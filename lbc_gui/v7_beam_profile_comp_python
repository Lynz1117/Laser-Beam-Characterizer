# ============================================================
# T0 scan processing
# ============================================================
def process_initial_t0_scan_for_width(scan0, t0_idx=None, t0_info=None):
    """
    Estimate beam width directly from the initial T0 scan,
    but force alignment to the already-found T0 from scan0.

    Method:
      1) sort by x_mm
      2) SG smooth the power
      3) fit an erf in physical x
      4) take absolute derivative of fitted erf as beam profile
      5) align x to the previously found T0 position
      6) compute sigma and 4sigma from that inferred profile
    """
    if scan0 is None:
        return None

    raw = np.asarray(scan0["raw"], dtype=float)
    x_mm = np.asarray(scan0["x_mm"], dtype=float)
    p_mw = np.asarray(scan0["p_mw"], dtype=float)

    if len(raw) < 10 or len(x_mm) < 10 or len(p_mw) < 10:
        return None

    # Get the trusted T0 position from the already-found initial-scan result
    if t0_info is not None and "x_mm" in t0_info:
        x_t0_ref = float(t0_info["x_mm"])
    elif t0_idx is not None and 0 <= int(t0_idx) < len(x_mm):
        x0_start = float(x_mm[0])
        x_t0_ref = float(x_mm[int(t0_idx)] - x0_start)
    else:
        return None

    # Sort the scan by physical position
    order = np.argsort(x_mm)
    x_mm = x_mm[order]
    p_mw = p_mw[order]

    # Average duplicate positions
    x_mm, averaged = average_duplicate_positions(x_mm, p_mw)
    p_mw = averaged[0]

    if len(x_mm) < 5:
        return None

    # Smooth power before fitting
    p_sg = sg_smooth_5point(p_mw)

    # Fit an erf in physical x only to get a smooth derivative/profile shape
    fit = fit_erf_curve_x_simple(x_mm, p_sg)

    fit_y, fit_d = build_erf_fit_and_derivative_x(
        x_mm,
        fit["x0"],
        fit["w"],
        fit["y_lo"],
        fit["y_hi"],
    )

    # Beam profile inferred from derivative of fitted knife-edge
    profile_full = np.abs(fit_d)

    # IMPORTANT: align to the already-found T0, not the fit center
    x_mm_rel = x_mm - x_t0_ref

    # Crop around main lobe for cleaner width stats
    x_prof, profile = crop_main_lobe(x_mm_rel, profile_full)

    mu, sigma, width_4sigma = weighted_stats_from_profile(x_prof, profile)

    # Keep normalized knife-edge for plotting/inspection
    P = knife_from_monotonic_power(fit_y)

    return {
        "x_mm": x_mm_rel,
        "p_mw": fit_y,
        "P": P,
        "P_plot": scale_normalized_to_power(P, fit_y),
        "profile_full": profile_full,
        "x_prof": x_prof,
        "profile": profile,
        "x_t0": x_t0_ref,          # trusted T0 from initial scan
        "x_fit_center": float(fit["x0"]),  # optional debug: model center
        "mu": mu,
        "sigma": sigma,
        "width_4sigma": width_4sigma,
        "mode": "initial_t0_scan",
        "fit": fit,
        "p_raw_sorted": p_mw,
        "p_sg": p_sg,
    }


# ============================================================
# Repeated scan processing
# ============================================================
def process_repeated_scan(scan):
    raw = np.asarray(scan["raw"], dtype=float)
    enc = np.asarray(scan["enc"], dtype=float)
    deg = np.asarray(scan["deg"], dtype=float)
    v = np.asarray(scan["v"], dtype=float)
    p_mw = np.asarray(scan["p_mw"], dtype=float)

    if len(raw) < 10:
        return None

    x_mm = np.asarray(scan["x_mm"], dtype=float)

    order = np.argsort(x_mm)
    x_mm = x_mm[order]
    raw = raw[order]
    enc = enc[order]
    deg = deg[order]
    v = v[order]
    p_mw = p_mw[order]

    x_mm, averaged = average_duplicate_positions(x_mm, raw, enc, deg, v, p_mw)
    raw, enc, deg, v, p_mw = averaged

    if len(x_mm) < 5:
        return None

    # Repeated scans use the same SG pre-smoothing as the initial T0 fit.
    # For monotonic knife-edge traces, we then fit an erf and differentiate
    # the fitted curve so the beam profile comes from a smoothed physical model.
    p_sg = sg_smooth_5point(p_mw)
    mono_diag = monotonic_diagnostics(p_sg)
    strong_edge_span = mono_diag["edge_span_ratio"] >= EDGE_SPAN_RATIO_THRESH
    monotonic_mode = True if scan.get("synthetic", False) else (strong_edge_span or is_mostly_monotonic(p_sg))

    if monotonic_mode:
        fit = fit_erf_curve_x_simple(x_mm, p_sg)
        fit_y, fit_d = build_erf_fit_and_derivative_x(
            x_mm,
            fit["x0"],
            fit["w"],
            fit["y_lo"],
            fit["y_hi"],
        )

        P = knife_from_monotonic_power(fit_y)
        dPdx = np.gradient(P, x_mm)
        x_t0 = float(fit["x0"])

        profile_full = np.abs(fit_d)
        p_used = fit_y
    else:
        p_used = moving_average(p_sg, MA_W_P)
        P, profile_full = profile_from_hump_power(x_mm, p_used)

        # local T0 from integrated-profile knife-edge midpoint
        # more stable than centroid for alignment
        x_t0 = crossing_x_at_level(x_mm, P, 0.5)
        dPdx = np.gradient(P, x_mm)

    # Align everything to local T0, not centroid
    x_mm_rel = x_mm - x_t0

    if monotonic_mode:
        x_prof = x_mm_rel
        profile = profile_full
    else:
        if np.max(profile_full) > 0:
            profile_full = np.where(profile_full >= 0.04 * np.max(profile_full), profile_full, 0.0)
        x_prof, profile = crop_main_lobe(x_mm_rel, profile_full)

    mu, sigma, width_4sigma = weighted_stats_from_profile(x_prof, profile)

    return {
        "x_mm": x_mm_rel,
        "deg": deg,
        "enc": enc,
        "raw": raw,
        "v": v,
        "p_mw": p_used,
        "P": P,
        "P_plot": scale_normalized_to_power(P, p_used),
        "dPdx": dPdx,
        "profile_full": profile_full,
        "x_prof": x_prof,
        "profile": profile,
        "mu": mu,
        "sigma": sigma,
        "width_4sigma": width_4sigma,
        "x_center": 0.0,
        "x_t0": x_t0,
        "mode": "knife_edge" if monotonic_mode else "profile_integrated",
        "mono_score": mono_diag["mono_score"],
        "interior_peak": mono_diag["interior_peak"],
        "interior_valley": mono_diag["interior_valley"],
        "edge_left_level": mono_diag["left_level"],
        "edge_right_level": mono_diag["right_level"],
        "end_to_end": mono_diag["end_to_end"],
        "total_var": mono_diag["total_var"],
        "edge_span_ratio": mono_diag["edge_span_ratio"],
        "forced_synthetic_monotonic": bool(scan.get("synthetic", False)),
    }

def average_processed_scans(results):
    if not results:
        return None
    if len(results) == 1:
        return results[0]

    x0 = max(r["x_mm"][0] for r in results)
    x1 = min(r["x_mm"][-1] for r in results)
    if x1 <= x0:
        return None

    n = min(len(r["x_mm"]) for r in results)
    x_common = np.linspace(x0, x1, n)

    p_stack = []
    P_stack = []
    d_stack = []
    prof_stack = []

    for r in results:
        p_stack.append(np.interp(x_common, r["x_mm"], r["p_mw"]))
        P_stack.append(np.interp(x_common, r["x_mm"], r["P"]))
        d_stack.append(np.interp(x_common, r["x_mm"], r["dPdx"]))
        prof_stack.append(np.interp(x_common, r["x_mm"], r["profile_full"]))

    p_avg = np.mean(np.vstack(p_stack), axis=0)
    P_avg = np.mean(np.vstack(P_stack), axis=0)
    d_avg = np.mean(np.vstack(d_stack), axis=0)
    prof_full_avg = np.mean(np.vstack(prof_stack), axis=0)

    all_knife_edge = all(r.get("mode") == "knife_edge" for r in results)

    if all_knife_edge:
        x_prof = x_common
        prof_avg = prof_full_avg
        mode = "knife_edge_avg"
    else:
        if np.max(prof_full_avg) > 0:
            prof_full_avg = np.where(prof_full_avg >= 0.04 * np.max(prof_full_avg), prof_full_avg, 0.0)
        x_prof, prof_avg = crop_main_lobe(x_common, prof_full_avg)
        mode = "avg"

    mu, sigma, width_4sigma = weighted_stats_from_profile(x_prof, prof_avg)

    return {
        "x_mm": x_common,
        "deg": None,
        "p_mw": p_avg,
        "P": P_avg,
        "P_plot": scale_normalized_to_power(P_avg, p_avg),
        "dPdx": d_avg,
        "profile_full": prof_full_avg,
        "x_prof": x_prof,
        "profile": prof_avg,
        "mu": mu,
        "sigma": sigma,
        "width_4sigma": width_4sigma,
        "x_center": 0.0,
        "x_t0": 0.0,
        "mode": mode,
    }


