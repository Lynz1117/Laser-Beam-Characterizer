def sg_smooth_5point(y):
    """
    5-point Savitzky-Golay smoothing, same style as the STM32 helper.
    For interior points:
        y_s[i] = (-3*y[i-2] + 12*y[i-1] + 17*y[i] + 12*y[i+1] - 3*y[i+2]) / 35
    Endpoints fall back to edge-copy behavior.
    """
    y = np.asarray(y, dtype=float)
    n = len(y)
    if n < 5:
        return y.copy()

    ys = y.copy()

    # Keep ends simple and stable
    ys[0] = y[0]
    ys[1] = y[1]
    ys[-2] = y[-2]
    ys[-1] = y[-1]

    for i in range(2, n - 2):
        ys[i] = (
            -3.0 * y[i - 2]
            + 12.0 * y[i - 1]
            + 17.0 * y[i]
            + 12.0 * y[i + 1]
            - 3.0 * y[i + 2]
        ) / 35.0

    return ys


def erf_model_idx(x_idx, x0_idx, w_idx, y_lo, y_hi):
    """
    Error-function model versus sample index.
    """
    w_idx = max(float(w_idx), 1e-9)
    a = 0.5 * (y_hi - y_lo)

    x_idx = np.asarray(x_idx, dtype=float)
    z = (x_idx - float(x0_idx)) / w_idx

    # numpy may not have vectorized erf in all environments, so use list comprehension
    erf_vals = np.array([math.erf(val) for val in z], dtype=float)
    return 0.5 * (y_hi + y_lo) + a * erf_vals


def build_erf_fit_and_derivative(n, dt_s, x0_idx, w_idx, y_lo, y_hi):
    """
    Build:
      fit_y[i] = fitted erf curve
      fit_d[i] = derivative of fitted erf w.r.t. time
    Mirrors the STM32 logic:
      d/dx erf((x-x0)/w) = (2/sqrt(pi)) * exp(-z^2) / w
      dx/dt = 1/dt_s
    """
    x = np.arange(n, dtype=float)
    w_idx = max(float(w_idx), 1e-9)

    a = 0.5 * (y_hi - y_lo)
    z = (x - float(x0_idx)) / w_idx

    fit_y = erf_model_idx(x, x0_idx, w_idx, y_lo, y_hi)
    fit_d = a * (2.0 / math.sqrt(math.pi)) * np.exp(-(z * z)) / (w_idx * dt_s)

    return fit_y, fit_d


def estimate_erf_initial_params(y):
    """
    Initial guess for erf fit parameters.
    """
    y = np.asarray(y, dtype=float)
    n = len(y)
    x = np.arange(n, dtype=float)

    k = max(3, n // 10)
    y_lo = float(np.median(y[:k]))
    y_hi = float(np.median(y[-k:]))

    y_mid = 0.5 * (y_lo + y_hi)
    x0_idx = float(x[np.argmin(np.abs(y - y_mid))])

    dy = np.gradient(y)
    peak = float(np.max(np.abs(dy))) if len(dy) else 0.0
    amp = abs(y_hi - y_lo)

    if peak > 1e-12:
        # rough width estimate from local slope
        # slope near center of erf is a*(2/sqrt(pi))/w
        a = 0.5 * amp
        if a > 1e-12:
            w_idx = max((a * (2.0 / math.sqrt(math.pi))) / peak, 2.0)
        else:
            w_idx = max(n / 20.0, 2.0)
    else:
        w_idx = max(n / 20.0, 2.0)

    return x0_idx, w_idx, y_lo, y_hi


def fit_erf_curve_simple(y, max_iters=80):
    """
    Lightweight erf fit without SciPy.
    Coordinate-descent style refinement on:
      x0_idx, w_idx, y_lo, y_hi

    Returns fitted parameters in sample-index units.
    """
    y = np.asarray(y, dtype=float)
    n = len(y)
    x = np.arange(n, dtype=float)

    x0, w, y_lo, y_hi = estimate_erf_initial_params(y)

    def sse(params):
        px0, pw, py_lo, py_hi = params
        if pw < 1e-6:
            return 1e30
        yf = erf_model_idx(x, px0, pw, py_lo, py_hi)
        e = y - yf
        return float(np.dot(e, e))

    params = [x0, w, y_lo, y_hi]
    best = sse(params)

    step_x0 = max(8.0, n * 0.03)
    step_w = max(4.0, n * 0.02)
    step_y = max(1e-6, 0.05 * max(abs(y_hi - y_lo), 1e-6))

    for _ in range(max_iters):
        improved = False

        candidates = [
            [params[0] + step_x0, params[1], params[2], params[3]],
            [params[0] - step_x0, params[1], params[2], params[3]],
            [params[0], params[1] + step_w, params[2], params[3]],
            [params[0], max(2.0, params[1] - step_w), params[2], params[3]],
            [params[0], params[1], params[2] + step_y, params[3]],
            [params[0], params[1], params[2] - step_y, params[3]],
            [params[0], params[1], params[2], params[3] + step_y],
            [params[0], params[1], params[2], params[3] - step_y],
        ]

        for cand in candidates:
            val = sse(cand)
            if val < best:
                params = cand
                best = val
                improved = True

        if not improved:
            step_x0 *= 0.5
            step_w *= 0.5
            step_y *= 0.5

            if step_x0 < 0.05 and step_w < 0.05 and step_y < 1e-6:
                break

    return {
        "x0_idx": float(params[0]),
        "w_idx": max(float(params[1]), 2.0),
        "y_lo": float(params[2]),
        "y_hi": float(params[3]),
        "sse": float(best),
    }


def erf_model_x(x, x0, w, y_lo, y_hi):
    """
    Error-function model versus physical position in mm.
    """
    x = np.asarray(x, dtype=float)
    w = max(float(w), 1e-9)
    a = 0.5 * (y_hi - y_lo)
    z = (x - float(x0)) / w
    erf_vals = np.array([math.erf(val) for val in z], dtype=float)
    return 0.5 * (y_hi + y_lo) + a * erf_vals


def estimate_erf_initial_params_x(x, y):
    """
    Initial guess for erf fit parameters on a physical x-axis.
    """
    x = np.asarray(x, dtype=float)
    y = np.asarray(y, dtype=float)

    if len(x) < 2:
        return 0.0, 1.0, float(y[0]), float(y[-1])

    k = max(3, len(y) // 10)
    y_lo = float(np.median(y[:k]))
    y_hi = float(np.median(y[-k:]))

    y_mid = 0.5 * (y_lo + y_hi)
    x0 = float(x[np.argmin(np.abs(y - y_mid))])

    dy_dx = np.gradient(y, x)
    peak = float(np.max(np.abs(dy_dx))) if len(dy_dx) else 0.0
    amp = abs(y_hi - y_lo)
    dx_med = float(np.median(np.diff(x)))
    dx_min = max(abs(dx_med), 1e-6)

    if peak > 1e-12:
        a = 0.5 * amp
        if a > 1e-12:
            w = max((a * (2.0 / math.sqrt(math.pi))) / peak, 2.0 * dx_min)
        else:
            w = max(0.05 * abs(float(x[-1] - x[0])), 2.0 * dx_min)
    else:
        w = max(0.05 * abs(float(x[-1] - x[0])), 2.0 * dx_min)

    return x0, w, y_lo, y_hi


def fit_erf_curve_x_simple(x, y, max_iters=80):
    """
    Lightweight erf fit without SciPy on a physical x-axis.
    """
    x = np.asarray(x, dtype=float)
    y = np.asarray(y, dtype=float)

    x0, w, y_lo, y_hi = estimate_erf_initial_params_x(x, y)

    def sse(params):
        px0, pw, py_lo, py_hi = params
        if pw < 1e-6:
            return 1e30
        yf = erf_model_x(x, px0, pw, py_lo, py_hi)
        e = y - yf
        return float(np.dot(e, e))

    params = [x0, w, y_lo, y_hi]
    best = sse(params)

    x_span = max(abs(float(x[-1] - x[0])), 1e-6)
    dx_med = max(abs(float(np.median(np.diff(x)))), 1e-6)

    step_x0 = max(4.0 * dx_med, 0.03 * x_span)
    step_w = max(2.0 * dx_med, 0.02 * x_span)
    step_y = max(1e-6, 0.05 * max(abs(y_hi - y_lo), 1e-6))

    for _ in range(max_iters):
        improved = False

        candidates = [
            [params[0] + step_x0, params[1], params[2], params[3]],
            [params[0] - step_x0, params[1], params[2], params[3]],
            [params[0], params[1] + step_w, params[2], params[3]],
            [params[0], max(2.0 * dx_med, params[1] - step_w), params[2], params[3]],
            [params[0], params[1], params[2] + step_y, params[3]],
            [params[0], params[1], params[2] - step_y, params[3]],
            [params[0], params[1], params[2], params[3] + step_y],
            [params[0], params[1], params[2], params[3] - step_y],
        ]

        for cand in candidates:
            val = sse(cand)
            if val < best:
                params = cand
                best = val
                improved = True

        if not improved:
            step_x0 *= 0.5
            step_w *= 0.5
            step_y *= 0.5

            if step_x0 < 0.1 * dx_med and step_w < 0.1 * dx_med and step_y < 1e-6:
                break

    return {
        "x0": float(params[0]),
        "w": max(float(params[1]), 2.0 * dx_med),
        "y_lo": float(params[2]),
        "y_hi": float(params[3]),
        "sse": float(best),
    }


def build_erf_fit_and_derivative_x(x, x0, w, y_lo, y_hi):
    """
    Build fitted erf curve and derivative with respect to x in mm.
    """
    x = np.asarray(x, dtype=float)
    w = max(float(w), 1e-9)

    a = 0.5 * (y_hi - y_lo)
    z = (x - float(x0)) / w

    fit_y = erf_model_x(x, x0, w, y_lo, y_hi)
    fit_d = a * (2.0 / math.sqrt(math.pi)) * np.exp(-(z * z)) / w

    return fit_y, fit_d


def find_t0_index_from_initial_power(scan0, dt_s=None, return_debug=False):
    """
    New T0 pipeline:
      1) use raw power samples from STM32
      2) SG smooth
      3) fit erf to SG-smoothed power
      4) differentiate fitted erf
      5) choose T0 from max absolute derivative

    dt_s defaults to the raw ADC sample interval used by the STM32 stream.
    """
    p_raw = np.asarray(scan0["p_mw"], dtype=float)
    n = len(p_raw)

    if dt_s is None:
        t_ms = np.asarray(scan0.get("t_ms", []), dtype=float)
        if len(t_ms) >= 2:
            dt_s = 1e-3 * float(np.median(np.diff(t_ms)))
        else:
            dt_s = RAW_SAMPLE_DT_S

    if n < 7:
        if return_debug:
            return 0, {
                "p_raw": p_raw.copy(),
                "p_sg": p_raw.copy(),
                "fit_y": p_raw.copy(),
                "fit_d": np.zeros_like(p_raw),
                "fit": None,
            }
        return 0

    # 1-2) SG smoothing
    p_sg = sg_smooth_5point(p_raw)

    # 3) erf fit
    fit = fit_erf_curve_simple(p_sg)

    # 4) fitted erf + derivative of fitted erf
    fit_y, fit_d = build_erf_fit_and_derivative(
        n=n,
        dt_s=dt_s,
        x0_idx=fit["x0_idx"],
        w_idx=fit["w_idx"],
        y_lo=fit["y_lo"],
        y_hi=fit["y_hi"],
    )

    # 5) choose T0 from derivative peak
    t0_idx = int(np.argmax(np.abs(fit_d)))

    if return_debug:
        return t0_idx, {
            "p_raw": p_raw,
            "p_sg": p_sg,
            "fit_y": fit_y,
            "fit_d": fit_d,
            "fit": fit,
        }

    return t0_idx


def build_t0_info_from_initial_scan(scan0, t0_idx):
    if scan0 is None:
        return None
    if t0_idx < 0 or t0_idx >= len(scan0["t_ms"]):
        return None

    deg0 = scan0["deg"][0]
    deg_t0 = float(scan0["deg"][t0_idx] - deg0)
    x0 = scan0["x_mm"][0]
    x_t0 = float(scan0["x_mm"][t0_idx] - x0)

    return {
        "idx": int(t0_idx),
        "t_ms": float(scan0["t_ms"][t0_idx]),
        "deg": deg_t0,
        "x_mm": x_t0,
        "raw": int(scan0["raw"][t0_idx]),
        "stage": int(scan0["stage"][t0_idx]),
        "v": float(scan0["v"][t0_idx]),
        "p_mw": float(scan0["p_mw"][t0_idx]),
    }


def compute_first_repeat_start_counts(scan0, t0_idx):
    if scan0 is None:
        return PROFILE_WAIT_COUNTS + (PROFILE_REPEAT_COUNTS // 2)

    enc = np.asarray(scan0["enc"], dtype=int)
    if len(enc) < 2 or t0_idx < 0 or t0_idx >= len(enc):
        return PROFILE_WAIT_COUNTS + (PROFILE_REPEAT_COUNTS // 2)

    enc_start = int(enc[0])
    enc_end = int(enc[-1])
    t0_enc = int(enc[t0_idx])

    dir_sign = 1 if encoder_delta_counts(enc_end, enc_start) >= 0 else -1

    x0_counts = dir_sign * encoder_delta_counts(t0_enc, enc_start)
    x0_counts = max(0, int(x0_counts))

    init_counts_measured = abs(encoder_delta_counts(enc_end, enc_start))

    # --- nominal first target ---
    xs1 = PROFILE_WAIT_COUNTS + (PROFILE_REPEAT_COUNTS // 2) + x0_counts

    period = PROFILE_EVENT_COUNTS

    # --- ensure after initial scan ---
    while xs1 < init_counts_measured:
        xs1 += period

    # 🔥 NEW: emulate STM skip-ahead behavior
    # Estimate how far encoder moved during T0 compute
    # (use end-to-start delta as proxy)
    arm_delay = init_counts_measured * 0.25   # heuristic

    simulated_now = init_counts_measured + arm_delay

    while xs1 <= simulated_now:
        xs1 += period

    return int(xs1)


def build_axis_scan_count_log(axis, scan0, t0_idx, first_repeat_start_counts, repeated_scans):
    axis_label = axis + 1
    lines = [f"[Axis {axis_label}]"]

    lines.append(f"initial_target_counts={PROFILE_INIT_COUNTS}")
    lines.append(f"repeat_target_counts={PROFILE_REPEAT_COUNTS}")
    lines.append(f"repeat_half_counts={PROFILE_REPEAT_COUNTS // 2}")
    lines.append(f"t90_counts={PROFILE_EVENT_COUNTS}")
    lines.append(f"twait_counts={PROFILE_WAIT_COUNTS}")
    lines.append(f"first_repeat_start_counts={first_repeat_start_counts}")

    if scan0 is None or len(scan0["enc"]) < 2:
        lines.append("initial_measured_counts=unavailable")
        return "\n".join(lines)

    init_enc = np.asarray(scan0["enc"], dtype=int)
    init_start = int(init_enc[0])
    init_end = int(init_enc[-1])
    init_span_signed = encoder_delta_counts(init_end, init_start)
    dir_sign = 1 if init_span_signed >= 0 else -1
    init_span = abs(init_span_signed)
    lines.append(f"initial_measured_counts={init_span}")

    if 0 <= t0_idx < len(init_enc):
        t0_enc = int(init_enc[t0_idx])
        x0_counts = max(0, dir_sign * encoder_delta_counts(t0_enc, init_start))
        counts_after_t0 = max(0, dir_sign * encoder_delta_counts(init_end, t0_enc))
        first_wait_counts = max(0, first_repeat_start_counts - init_span)
        lines.append(f"t0_counts_from_initial_start={x0_counts}")
        lines.append(f"counts_after_t0_to_initial_end={counts_after_t0}")
        lines.append(
            "first_repeat_start_formula="
            f"{PROFILE_WAIT_COUNTS}+{PROFILE_REPEAT_COUNTS // 2}+{x0_counts}"
            f"={first_repeat_start_counts}"
        )
        lines.append(f"first_wait_counts={first_wait_counts}")
        lines.append(
            "first_wait_formula="
            f"{first_repeat_start_counts}-{init_span}"
            f"={first_wait_counts}"
        )
    else:
        t0_enc = None
        lines.append("t0_counts_from_initial_start=unavailable")
        lines.append("counts_after_t0_to_initial_end=unavailable")

    if repeated_scans:
        first_repeat_enc = np.asarray(repeated_scans[0]["enc"], dtype=int)
        if len(first_repeat_enc) >= 1:
            first_start_from_init_start = encoder_step_distance(int(first_repeat_enc[0]), init_start)
            first_gap = encoder_step_distance(int(first_repeat_enc[0]), init_end)
            lines.append(f"first_repeat_start_measured_counts={first_start_from_init_start}")
            lines.append(f"first_wait_measured_counts={first_gap}")

    prev_start = None
    prev_end = init_end
    for scan in repeated_scans:
        scan_no = int(scan["scan_no"])
        enc = np.asarray(scan["enc"], dtype=int)
        if len(enc) < 2:
            lines.append(f"repeat_{scan_no:02d}_measured_counts=unavailable")
            continue

        start = int(enc[0])
        end = int(enc[-1])
        span = encoder_step_distance(end, start)
        wait_from_prev_end = encoder_step_distance(start, prev_end)

        lines.append(f"repeat_{scan_no:02d}_measured_counts={span}")
        lines.append(f"repeat_{scan_no:02d}_wait_from_prev_end_counts={wait_from_prev_end}")

        if prev_start is not None:
            start_to_start = encoder_step_distance(start, prev_start)
            lines.append(f"repeat_{scan_no:02d}_start_to_start_counts={start_to_start}")

        prev_start = start
        prev_end = end

    return "\n".join(lines)


