def should_echo_serial_line(line):
    return not (
        line.startswith("RAW_SCAN,")
        or line.startswith("RAW_SCAN_BEGIN")
        or line.startswith("RAW_SCAN_DONE")
    )


def read_axis_sequence(ser, axis, expected_repeats):
    collector = RawScanCollector()
    scans_by_no = {}
    empty_count = 0
    done_seen = False

    while empty_count < REPEAT_EMPTY_LIMIT and not done_seen:
        raw_line = ser.readline()
        if not raw_line:
            empty_count += 1
            if empty_count % 10 == 0:
                print(f"[waiting] axis={axis} no data yet ({empty_count} / {REPEAT_EMPTY_LIMIT})")
            continue

        empty_count = 0
        line = raw_line.decode(errors="ignore").strip()
        if not line:
            continue

        if should_echo_serial_line(line):
            print(line)

        if line.startswith("RAW_SCAN_BEGIN"):
            parts = parse_keyvals_csv(line)
            stride = float(parts.get("stride", "1"))
            emit_stride = float(parts.get("emit_stride", "1"))
            collector.start(
                int(parts["axis"]),
                int(parts["scan"]),
                sample_dt_ms=(1000.0 * RAW_SAMPLE_DT_S * stride * emit_stride),
                synthetic=(int(parts.get("synthetic", "0")) != 0),
            )
            continue

        if line.startswith("RAW_SCAN,"):
            parts = line.split(",")
            if len(parts) == 11:
                collector.add(
                    idx=int(parts[3]),
                    enc=int(parts[4]),
                    deg=float(parts[5]),
                    x_mm=float(parts[6]),
                    stage=int(parts[7]),
                    raw=int(parts[8]),
                    v=float(parts[9]),
                    p_mw=float(parts[10]),
                )
            continue

        if line.startswith("RAW_SCAN_DONE"):
            scan = collector.finalize()
            if scan is not None and scan["axis"] == axis:
                scans_by_no[scan["scan_no"]] = scan
            continue

        if line.startswith("AXIS_DONE_READY_FOR_NEXT") and axis == 0:
            done_seen = True
            continue

        if line.startswith("PROFILE_DONE") and axis == 1:
            done_seen = True
            continue

    if 0 not in scans_by_no:
        got = sorted(scans_by_no.keys())
        raise RuntimeError(
            f"Axis {axis} completed but initial scan 0 was never received. "
            f"Got scans: {got}"
        )

    repeated_scans = [scans_by_no[k] for k in sorted(scans_by_no.keys()) if k >= 1]
    if len(repeated_scans) != expected_repeats:
        print(
            f"[warn] axis={axis} expected {expected_repeats} repeated scans, "
            f"got {len(repeated_scans)}"
        )

    return scans_by_no[0], repeated_scans


