def ensure_dir(path: str) -> None:
    os.makedirs(path, exist_ok=True)


def moving_average(y, w):
    y = np.asarray(y, dtype=float)
    if len(y) < max(3, w):
        return y.copy()
    if w % 2 == 0:
        w += 1
    pad = w // 2
    ypad = np.pad(y, (pad, pad), mode="edge")
    k = np.ones(w, dtype=float) / float(w)
    return np.convolve(ypad, k, mode="valid")


def normalize_01(y):
    y = np.asarray(y, dtype=float)
    y0 = np.min(y)
    y1 = np.max(y)
    if abs(y1 - y0) <= 1e-12:
        return np.zeros_like(y)
    return (y - y0) / (y1 - y0)


def encoder_delta_counts(enc_now, enc_ref):
    d = int(enc_now) - int(enc_ref)
    return int(((d + (ENCODER_TIMER_MOD // 2)) % ENCODER_TIMER_MOD) - (ENCODER_TIMER_MOD // 2))


def encoder_step_distance(enc_now, enc_ref):
    return abs(encoder_delta_counts(enc_now, enc_ref))


def robust_edge_levels(sig, frac=EDGE_FRAC):
    sig = np.asarray(sig, dtype=float)
    n = len(sig)
    k = max(3, int(frac * n))
    left = np.median(sig[:k])
    right = np.median(sig[-k:])
    return left, right


def is_mostly_monotonic(y):
    diag = monotonic_diagnostics(y)
    if diag["edge_span_ratio"] >= EDGE_SPAN_RATIO_THRESH:
        return True

    if diag["mono_score"] < MONO_SCORE_THRESH and (diag["interior_peak"] or diag["interior_valley"]):
        return False

    return True


def monotonic_diagnostics(y):
    y = np.asarray(y, dtype=float)
    if len(y) < 8:
        return {
            "mono_score": 1.0,
            "interior_peak": False,
            "interior_valley": False,
            "left_level": float(y[0]) if len(y) else 0.0,
            "right_level": float(y[-1]) if len(y) else 0.0,
            "end_to_end": 0.0,
            "total_var": 0.0,
            "edge_span_ratio": 0.0,
        }

    dy = np.diff(y)
    if np.all(np.abs(dy) < 1e-12):
        left, right = robust_edge_levels(y)
        return {
            "mono_score": 1.0,
            "interior_peak": False,
            "interior_valley": False,
            "left_level": float(left),
            "right_level": float(right),
            "end_to_end": 0.0,
            "total_var": 0.0,
            "edge_span_ratio": 0.0,
        }

    total_var = np.sum(np.abs(dy)) + 1e-12
    end_to_end = abs(y[-1] - y[0])
    mono_score = end_to_end / total_var
    left, right = robust_edge_levels(y)
    full_span = max(float(np.max(y) - np.min(y)), 1e-12)
    edge_span_ratio = abs(right - left) / full_span

    i_peak = int(np.argmax(y))
    i_valley = int(np.argmin(y))
    interior_peak = (0 < i_peak < len(y) - 1)
    interior_valley = (0 < i_valley < len(y) - 1)

    return {
        "mono_score": float(mono_score),
        "interior_peak": bool(interior_peak),
        "interior_valley": bool(interior_valley),
        "left_level": float(left),
        "right_level": float(right),
        "end_to_end": float(end_to_end),
        "total_var": float(total_var),
        "edge_span_ratio": float(edge_span_ratio),
    }


def knife_from_monotonic_power(p_s):
    left, right = robust_edge_levels(p_s)

    P = (p_s - left) / (right - left + 1e-12)
    P = np.clip(P, 0.0, 1.0)

    k = max(3, len(P) // 10)
    if np.mean(P[:k]) < np.mean(P[-k:]):
        P = 1.0 - P

    P = moving_average(P, MA_W_P)
    P = np.clip(P, 0.0, 1.0)
    return P


def scale_normalized_to_power(P, p_ref):
    P = np.asarray(P, dtype=float)
    p_ref = np.asarray(p_ref, dtype=float)

    if len(P) == 0 or len(p_ref) == 0:
        return P.copy()

    p_lo = float(np.min(p_ref))
    p_hi = float(np.max(p_ref))
    return p_lo + P * (p_hi - p_lo)


def average_duplicate_positions(x, *arrays):
    x = np.asarray(x, dtype=float)
    if len(x) == 0:
        return x.copy(), [np.asarray(a, dtype=float).copy() for a in arrays]

    x_unique, inverse, counts = np.unique(x, return_inverse=True, return_counts=True)
    counts = counts.astype(float)

    averaged = []
    for arr in arrays:
        arr = np.asarray(arr, dtype=float)
        sums = np.bincount(inverse, weights=arr, minlength=len(x_unique))
        averaged.append(sums / counts)

    return x_unique, averaged


def profile_from_hump_power(x_mm, p_s):
    left, right = robust_edge_levels(p_s)
    baseline = min(left, right)

    prof = p_s - baseline
    prof = np.maximum(prof, 0.0)
    prof = moving_average(prof, MA_W_D)
    prof = np.maximum(prof, 0.0)

    if np.max(prof) > 0:
        prof = np.where(prof >= 0.03 * np.max(prof), prof, 0.0)

    dx = float(np.median(np.diff(x_mm)))
    P_rise = np.cumsum(prof) * dx
    P_rise = normalize_01(P_rise)

    P = 1.0 - P_rise
    P = moving_average(P, MA_W_P)
    P = np.clip(P, 0.0, 1.0)

    return P, prof


def crossing_x_at_level(x, y, level=0.5):
    x = np.asarray(x, dtype=float)
    y = np.asarray(y, dtype=float)

    if len(x) < 2:
        return 0.0

    s = y - level
    idx = np.where(np.signbit(s[:-1]) != np.signbit(s[1:]))[0]
    if len(idx) == 0:
        return float(x[np.argmin(np.abs(s))])

    i = idx[0]
    x0, x1 = x[i], x[i + 1]
    y0, y1 = y[i], y[i + 1]

    if abs(y1 - y0) < 1e-12:
        return float(x0)

    return float(x0 + (level - y0) * (x1 - x0) / (y1 - y0))


def weighted_stats_from_profile(x, prof):
    x = np.asarray(x, dtype=float)
    prof = np.asarray(prof, dtype=float)

    prof = np.maximum(prof, 0.0)
    s = float(np.sum(prof))
    if s <= 0 or len(x) < 3:
        return None, None, None

    mu = float(np.sum(x * prof) / s)
    var = float(np.sum(prof * (x - mu) ** 2) / s)
    sigma = float(np.sqrt(max(var, 0.0)))
    width_4sigma = 4.0 * sigma
    return mu, sigma, width_4sigma


def crop_main_lobe(x, profile, half_win_mm=PROFILE_HALF_WIN_MM, thresh_frac=PROFILE_THRESH_FRAC):
    x = np.asarray(x, dtype=float)
    profile = np.asarray(profile, dtype=float)

    if len(x) < 5:
        return x, profile

    profile = np.maximum(profile, 0.0)
    i_peak = int(np.argmax(profile))
    x_peak = x[i_peak]
    p_peak = profile[i_peak]

    if p_peak <= 0:
        return x, profile

    keep = (x >= (x_peak - half_win_mm)) & (x <= (x_peak + half_win_mm))
    x_c = x[keep]
    p_c = profile[keep]

    if len(x_c) < 5:
        return x, profile

    thresh = thresh_frac * np.max(p_c)
    p_c = np.where(p_c >= thresh, p_c, 0.0)
    return x_c, p_c


