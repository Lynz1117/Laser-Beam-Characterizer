class RawScanCollector:
    def __init__(self):
        self.reset()

    def reset(self):
        self.axis = None
        self.scan_no = None
        self.idx = []
        self.enc = []
        self.deg = []
        self.x_mm = []
        self.stage = []
        self.raw = []
        self.v = []
        self.p_mw = []
        self.t_ms = []
        self.sample_dt_ms = 1000.0 * RAW_SAMPLE_DT_S
        self.synthetic = False

    def start(self, axis, scan_no, sample_dt_ms=None, synthetic=False):
        self.reset()
        self.axis = axis
        self.scan_no = scan_no
        if sample_dt_ms is not None:
            self.sample_dt_ms = float(sample_dt_ms)
        self.synthetic = bool(synthetic)

    def add(self, idx, enc, deg, x_mm, stage, raw, v, p_mw):
        self.idx.append(idx)
        self.enc.append(enc)
        self.deg.append(deg)
        self.x_mm.append(x_mm)
        self.stage.append(stage)
        self.raw.append(raw)
        self.v.append(v)
        self.p_mw.append(p_mw)

    def finalize(self):
        if self.axis is None:
            return None

        idx = np.asarray(self.idx, dtype=int)

        return {
            "axis": int(self.axis),
            "scan_no": int(self.scan_no),
            "idx": idx,
            "enc": np.asarray(self.enc, dtype=int),
            "deg": np.asarray(self.deg, dtype=float),
            "x_mm": np.asarray(self.x_mm, dtype=float),
            "stage": np.asarray(self.stage, dtype=int),
            "raw": np.asarray(self.raw, dtype=int),
            "v": np.asarray(self.v, dtype=float),
            "p_mw": np.asarray(self.p_mw, dtype=float),
            "t_ms": self.sample_dt_ms * idx.astype(float),
            "synthetic": self.synthetic,
        }


def build_replay_scan_paths(axis):
    axis_label = axis + 1
    axis_dir = os.path.join(REPLAY_RUN_ROOT, f"axis_{axis_label}")

    csvs = [os.path.join(axis_dir, f"axis{axis_label}_scan0_raw.csv")]
    for scan_no in range(1, NUM_REPEATED_SCANS + 1):
        csvs.append(os.path.join(axis_dir, f"axis{axis_label}_scan{scan_no}_raw.csv"))

    missing = [path for path in csvs if not os.path.exists(path)]
    if missing:
        raise FileNotFoundError(
            f"Replay mode is missing saved scan CSVs for axis {axis_label}: {missing[0]}"
        )

    return csvs


class ReplaySerial:
    def __init__(self, timeout):
        self.timeout = float(timeout)
        self.proc = None
        self.queue = queue.Queue()
        self.reader_thread = None

    def reset_input_buffer(self):
        while True:
            try:
                self.queue.get_nowait()
            except queue.Empty:
                break

    def reset_output_buffer(self):
        return

    def _pump_stdout(self):
        try:
            for line in self.proc.stdout:
                self.queue.put(line.encode("utf-8"))
        finally:
            self.queue.put(None)

    def _launch_axis(self, axis):
        self._stop_process()

        cmd = [sys.executable, REPLAY_SCRIPT, *build_replay_scan_paths(axis), "--axis", str(axis), "--emit-status"]

        if REPLAY_TIMING == "csv":
            cmd.extend(["--timing", "csv", "--speedup", str(REPLAY_SPEEDUP)])
        elif REPLAY_TIMING == "fixed":
            cmd.extend(["--timing", "fixed", "--fixed-delay-ms", str(REPLAY_FIXED_DELAY_MS)])
        else:
            cmd.extend(["--timing", "none"])

        self.proc = subprocess.Popen(
            cmd,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            bufsize=1,
        )
        self.reader_thread = threading.Thread(target=self._pump_stdout, daemon=True)
        self.reader_thread.start()

    def _stop_process(self):
        if self.proc is not None:
            if self.proc.poll() is None:
                self.proc.terminate()
                try:
                    self.proc.wait(timeout=1.0)
                except subprocess.TimeoutExpired:
                    self.proc.kill()
                    self.proc.wait(timeout=1.0)
            self.proc = None
        self.reader_thread = None
        self.reset_input_buffer()

    def write(self, data):
        if isinstance(data, bytes):
            cmd = data.decode(errors="ignore").strip()
        else:
            cmd = str(data).strip()

        if cmd.startswith("START_AXIS"):
            axis = int(cmd[-1])
            print(f"[replay] launching saved scan stream for axis {axis + 1}")
            self._launch_axis(axis)
        elif cmd.startswith("RUN_REPEAT"):
            print("[replay] RUN_REPEAT ignored because replay stream already includes repeated scans")

    def readline(self):
        try:
            item = self.queue.get(timeout=self.timeout)
        except queue.Empty:
            return b""

        if item is None:
            return b""
        return item

    def close(self):
        self._stop_process()


def open_scan_source():
    if REPLAY_TEST_MODE:
