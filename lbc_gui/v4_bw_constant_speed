def update_plots(result):
    if result is None:
        return

    line_v.set_data(result["x_mm"], result["p_mw"])
    line_p.set_data(result["x_mm"], result["P"])
    ax1.relim()
    ax1.autoscale_view()

    line_prof.set_data(result["x_prof"], result["profile"])
    ax2.relim()
    ax2.autoscale_view()

    axis_name = "Axis 1" if sess.display_axis == 0 else "Axis 2"

    if result["width_4sigma"] is not None:
        status_text.set_text(
            f"{axis_name}\n"
            f"4σ width = {result['width_4sigma']:.3f} mm\n"
            f"σ = {result['sigma']:.3f} mm\n"
            f"mode = {result.get('mode', 'unknown')}\n"
            f"runs = {sess.done_runs}/{sess.target_runs}"
        )
    else:
        status_text.set_text(
            f"{axis_name}\n"
            f"mode = {result.get('mode', 'unknown')}\n"
            f"runs = {sess.done_runs}/{sess.target_runs}"
        )

    fig1.canvas.draw_idle()
    fig2.canvas.draw_idle()
    
def show_axis(axis):
    if axis in (0, 1) and sess.last_result[axis] is not None:
        sess.display_axis = axis
        update_plots(sess.last_result[axis])
    else:
        print(f"No data available for Axis {axis + 1}")

