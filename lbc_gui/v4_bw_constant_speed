# Session state
# ============================================================
class Session:
    def __init__(self):
        self.active = False
        self.abort = False

        # target number of full STM32 PROFILE runs
        self.target_runs = 1
        self.done_runs = 0

        # current active axis from STM32 messages
        self.current_axis = None

        # current raw scan buffers
        self.cur_scan_no = None
        self.cur_t_ms = []
        self.cur_deg = []
        self.cur_v = []
        self.cur_raw = []
        self.cur_p_mw = []
        self.cur_stage = []

        # repeated raw scans grouped by axis for current run
        self.raw_scans_current_run = {0: [], 1: []}

        # repeated raw scans grouped by axis across all runs
        self.raw_scans_all = {0: [], 1: []}

        # processed repeated scans grouped by axis for current run
        self.processed_scans_current_run = {0: [], 1: []}

        # averaged result for each completed run, grouped by axis
        self.run_results = {0: [], 1: []}

        # currently displayed result by axis
        self.last_result = {0: None, 1: None}

        # which axis to show in the plots
        self.display_axis = 0

        self.scan_start_wall = None
        self.last_bm_wall = None

sess = Session()


def flush_rx():
    while True:
        try:
            rx_q.get_nowait()
        except queue.Empty:
            break


def reset_current_scan_buffers():
    sess.cur_scan_no = None
    sess.cur_t_ms.clear()
    sess.cur_deg.clear()
    sess.cur_v.clear()
    sess.cur_raw.clear()
    sess.cur_p_mw.clear()
    sess.cur_stage.clear()


def start_session(target_runs=1):
    sess.active = True
    sess.abort = False

    sess.target_runs = target_runs
    sess.done_runs = 0
    sess.current_axis = None

    sess.raw_scans_current_run = {0: [], 1: []}
    sess.raw_scans_all = {0: [], 1: []}

    sess.processed_scans_current_run = {0: [], 1: []}
    sess.run_results = {0: [], 1: []}

    sess.last_result = {0: None, 1: None}
    sess.display_axis = 0

    sess.scan_start_wall = time.time()
    sess.last_bm_wall = None

    reset_current_scan_buffers()
    flush_rx()

    if USE_FAKE_SERIAL:
        send_fake_scan(run_index=0)
    else:
        ser.reset_input_buffer()
        ser.reset_output_buffer()
        ser.write(START_CMD)


def start_next_profile_run():
    sess.current_axis = None
    sess.raw_scans_current_run = {0: [], 1: []}
    sess.processed_scans_current_run = {0: [], 1: []}
    sess.scan_start_wall = time.time()
    sess.last_bm_wall = None
    reset_current_scan_buffers()
    flush_rx()

    if USE_FAKE_SERIAL:
        send_fake_scan(run_index=sess.done_runs)
    else:
        ser.reset_input_buffer()
        ser.reset_output_buffer()
        ser.write(START_CMD)


def abort_session():
    sess.abort = True
    sess.active = False
    if not USE_FAKE_SERIAL:
        try:
            ser.write(ABORT_CMD)
        except Exception:
            pass

