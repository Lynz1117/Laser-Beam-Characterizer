def finalize_current_scan():
    if not sess.cur_t_ms or sess.current_axis is None:
        return

    raw_scan = {
        "axis": sess.current_axis,
        "scan_no": sess.cur_scan_no,
        "t_ms": np.array(sess.cur_t_ms, dtype=float),
        "deg": np.array(sess.cur_deg, dtype=float),
        "v": np.array(sess.cur_v, dtype=float),
        "raw": np.array(sess.cur_raw, dtype=int),
        "p_mw": np.array(sess.cur_p_mw, dtype=float),
        "stage": np.array(sess.cur_stage, dtype=int),
    }

    # Skip scan 0 (initial long scan), save repeated scans only
    if sess.cur_scan_no != 0:
        sess.raw_scans_current_run[sess.current_axis].append(raw_scan)
        sess.raw_scans_all[sess.current_axis].append(raw_scan)

    if sess.cur_p_mw:
        result = process_scan(sess.cur_t_ms, sess.cur_deg, sess.cur_p_mw, sess.cur_v)
    else:
        if not sess.cur_v:
            reset_current_scan_buffers()
            return
        result = process_scan(sess.cur_t_ms, sess.cur_deg, sess.cur_v, sess.cur_v)

    if result is not None and sess.cur_scan_no != 0:
        sess.processed_scans_current_run[sess.current_axis].append(result)

        avg_result = average_processed_scans(sess.processed_scans_current_run[sess.current_axis])
        if avg_result is not None:
            sess.last_result[sess.current_axis] = avg_result
            sess.display_axis = sess.current_axis
            update_plots(sess.last_result[sess.current_axis])

    reset_current_scan_buffers()


def finalize_current_run():
    for axis in (0, 1):
        if sess.processed_scans_current_run[axis]:
            run_avg = average_processed_scans(sess.processed_scans_current_run[axis])
            if run_avg is not None:
                sess.run_results[axis].append(run_avg)
                sess.last_result[axis] = run_avg

    sess.done_runs += 1

    if sess.target_runs > 1:
        for axis in (0, 1):
            if sess.run_results[axis]:
                grand_avg = average_processed_scans(sess.run_results[axis])
                if grand_avg is not None:
                    sess.last_result[axis] = grand_avg

    # default display: show axis 0 if available, otherwise axis 1
    if sess.last_result[0] is not None:
        sess.display_axis = 0
        update_plots(sess.last_result[0])
    elif sess.last_result[1] is not None:
        sess.display_axis = 1
        update_plots(sess.last_result[1])


def pump_serial():
    did_work = False

    while True:
        try:
            line = rx_q.get_nowait()
        except queue.Empty:
            break

        did_work = True
        print(line)

        if line == "BM_DONE":
            if sess.cur_t_ms:
                finalize_current_scan()
            continue

        axis_from_begin = parse_profile_begin_axis(line)
        if axis_from_begin is not None:
            sess.current_axis = axis_from_begin
            reset_current_scan_buffers()
            continue

        axis_done = parse_profile_axis_done(line)
        if axis_done is not None:
            print(f"Axis {axis_done} complete")

            # 🔴 FINALIZE any in-progress scan for that axis
            if sess.current_axis == axis_done and sess.cur_t_ms:
                finalize_current_scan()

            # Optional: reset current scan buffer for safety
            reset_current_scan_buffers()

            continue

        if line.startswith("PROFILE_T0") or line.startswith("PROFILE_SCAN_"):
            continue

        if line == "PROFILE_DONE":
            if sess.cur_t_ms:
                finalize_current_scan()

            finalize_current_run()

            if sess.abort:
                sess.active = False
            elif sess.done_runs < sess.target_runs:
                start_next_profile_run()
            else:
                sess.active = False

            continue

        if line == "PROFILE_ABORT":
            sess.active = False
            continue

        parsed = parse_bm(line)
        if parsed is None:
            continue

        if parsed["kind"] == "BM":
            sess.last_bm_wall = time.time()

            axis = parsed["axis"]
            scan_no = parsed["scan"]

            # Use axis from BM line directly
            if sess.current_axis is None:
                sess.current_axis = axis

            # If axis changes mid-stream, finalize previous scan first
            if axis != sess.current_axis and sess.cur_t_ms:
                finalize_current_scan()
                reset_current_scan_buffers()
                sess.current_axis = axis

            if sess.cur_scan_no is None:
                sess.cur_scan_no = scan_no
            elif scan_no != sess.cur_scan_no and sess.cur_t_ms:
                finalize_current_scan()
                sess.cur_scan_no = scan_no

            sess.cur_t_ms.append(parsed["t_ms"])
            sess.cur_deg.append(parsed["deg"])
            sess.cur_v.append(parsed["v"])
            sess.cur_raw.append(parsed["raw"])
            sess.cur_p_mw.append(parsed["p_mw"])
            sess.cur_stage.append(parsed["stage"])

    return did_work


